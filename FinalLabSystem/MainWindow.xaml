<Window x:Class="FinalLabSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FinalLabSystem.ViewModels"
        xmlns:menu="clr-namespace:FinalLabSystem.ViewModels.Menu"
        xmlns:svm="clr-namespace:FinalLabSystem.ViewModels.Settings"
        xmlns:conv="clr-namespace:FinalLabSystem.Views"
        Title="FinalLab" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft">
    <Window.Resources>
        <conv:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>
        <conv:LowStockTextConverter x:Key="LowStockTextConverter"/>
        <conv:LowStockBrushConverter x:Key="LowStockBrushConverter"/>

        <!-- Home menu -->
        <DataTemplate DataType="{x:Type menu:HomeMenuViewModel}">
            <Grid Background="#F5F7FA">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding WelcomeMessage}"
                               FontSize="28" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="#1A4A52"/>
                    <Border Background="#FFF3E0" Padding="16,10" Margin="0,24,0,0"
                            CornerRadius="8"
                            Visibility="{Binding LowStockCount, Converter={StaticResource IntToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#x26A0;" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Foreground="#E65100" FontSize="16" FontWeight="SemiBold"
                                       VerticalAlignment="Center">
                                <Run Text="تنبيه: يوجد"/>
                                <Run Text="{Binding LowStockCount, Mode=OneWay}"/>
                                <Run Text="أنواع أنابيب مخزونها منخفض — يُرجى المراجعة"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- Patients sub-menu -->
        <DataTemplate DataType="{x:Type menu:PatientsMenuViewModel}">
            <Grid Background="#F5F7FA">
                <UniformGrid Rows="2" Columns="2"
                             Width="760" Height="360"
                             HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="إضافة وتعديل بيانات المرضى"
                            Command="{Binding NavigateToAddEditPatientCommand}"
                            Margin="12" FontSize="22" FontWeight="SemiBold"
                            Background="#1976D2" Foreground="White"/>
                    <Button Content="إدخال نتائج التحاليل"
                            Command="{Binding NavigateToTestResultsCommand}"
                            Margin="12" FontSize="22" FontWeight="SemiBold"
                            Background="#455A64" Foreground="White"/>
                    <Button Content="تسليم نتائج التحاليل"
                            Command="{Binding NavigateToDeliveryCommand}"
                            Margin="12" FontSize="22" FontWeight="SemiBold"
                            Background="#2E7D32" Foreground="White"/>
                    <Button Content="البحث عن المريض"
                            Command="{Binding NavigateToSearchCommand}"
                            Margin="12" FontSize="22" FontWeight="SemiBold"
                            Background="#6A1B9A" Foreground="White"/>
                </UniformGrid>
            </Grid>
        </DataTemplate>

        <!-- System Settings sub-menu -->
        <DataTemplate DataType="{x:Type svm:SystemSettingsMenuViewModel}">
            <Grid Background="#F5F7FA">
                <UniformGrid Rows="1" Columns="2"
                             Width="760" Height="180"
                             HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="بيانات التحاليل"
                            Command="{Binding NavigateToTestDataCommand}"
                            Margin="12" FontSize="22" FontWeight="SemiBold"
                            Background="#00838F" Foreground="White"/>
                    <Button Content="إدارة الفئات والمجموعات"
                            Command="{Binding NavigateToCategoriesGroupsCommand}"
                            Margin="12" FontSize="22" FontWeight="SemiBold"
                            Background="#00838F" Foreground="White"/>
                </UniformGrid>
            </Grid>
        </DataTemplate>

        <!-- External Samples placeholder -->
        <DataTemplate DataType="{x:Type menu:ExternalSamplesMenuViewModel}">
            <Grid Background="#F5F7FA">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="العينات الخارجية" FontSize="24" FontWeight="Bold"
                               Foreground="#666" Margin="0,0,0,12"/>
                    <TextBlock Text="سيتم تفعيل هذه الميزة في المرحلة 4"
                               FontSize="16" Foreground="#999" Margin="0,0,0,20"/>
                    <Button Content="العودة للرئيسية"
                            Command="{Binding DataContext.ShowHomeMenuCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Width="150" Height="36" FontSize="14"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- Accounts -->
        <DataTemplate DataType="{x:Type menu:AccountsMenuViewModel}">
            <Grid Background="#F5F7FA">
                <UniformGrid Rows="3" Columns="2"
                             Width="760" Height="520"
                             HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="شركات التأمين"
                            Command="{Binding NavigateToCompaniesCommand}"
                            Margin="12" FontSize="22" FontWeight="SemiBold"
                            Background="#1976D2" Foreground="White"/>
                    <Button Content="نظام التسعير"
                            Command="{Binding NavigateToPricingCommand}"
                            Margin="12" FontSize="22" FontWeight="SemiBold"
                            Background="#455A64" Foreground="White"/>
                    <Button Content="فواتير العقود"
                            Command="{Binding NavigateToInvoicesCommand}"
                            Margin="12" FontSize="22" FontWeight="SemiBold"
                            Background="#2E7D32" Foreground="White"/>
                    <Button Content="درج النقدية"
                            Command="{Binding NavigateToCashDrawerCommand}"
                            Margin="12" FontSize="22" FontWeight="SemiBold"
                            Background="#E65100" Foreground="White"/>
                    <Button Content="تقرير العمولات"
                            Command="{Binding NavigateToCommissionReportCommand}"
                            Margin="12" FontSize="22" FontWeight="SemiBold"
                            Background="#6A1B9A" Foreground="White"/>
                    <Button Content="الأرصدة المستحقة"
                            Command="{Binding NavigateToOutstandingBalanceCommand}"
                            Margin="12" FontSize="22" FontWeight="SemiBold"
                            Background="#00695C" Foreground="White"/>
                </UniformGrid>
            </Grid>
        </DataTemplate>

        <!-- Backup placeholder -->
        <DataTemplate DataType="{x:Type menu:BackupMenuViewModel}">
            <Grid Background="#F5F7FA">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="النسخ الاحتياطي" FontSize="24" FontWeight="Bold"
                               Foreground="#666" Margin="0,0,0,12"/>
                    <TextBlock Text="سيتم تفعيل هذه الميزة في المرحلة 6"
                               FontSize="16" Foreground="#999" Margin="0,0,0,20"/>
                    <Button Content="العودة للرئيسية"
                            Command="{Binding DataContext.ShowHomeMenuCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Width="150" Height="36" FontSize="14"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- Report Settings -->
        <DataTemplate DataType="{x:Type menu:ReportSettingsMenuViewModel}">
            <Grid Background="#F5F7FA" Margin="20">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">
                    <TextBlock Text="إعدادات التقارير" FontSize="24" FontWeight="Bold"
                               Foreground="#333" Margin="0,0,0,20" TextAlignment="Center"/>

                    <Button Content="إدارة قالب التعليقات"
                            Command="{Binding ManageTemplatesCommand}"
                            Width="250" Height="40" FontSize="14" Margin="0,0,0,10"
                            HorizontalAlignment="Center"/>

                    <Button Content="إعدادات التنسيق والتخطيط"
                            Command="{Binding NavigateToReportSettingsCommand}"
                            Width="250" Height="40" FontSize="14" Margin="0,0,0,20"
                            HorizontalAlignment="Center"/>

                    <Button Content="العودة للرئيسية"
                            Command="{Binding DataContext.ShowHomeMenuCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Width="150" Height="36" FontSize="14"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <DockPanel Background="#F5F7FA">
        <ToolBarTray DockPanel.Dock="Top" Background="#263238">
            <ToolBar Background="#263238">
                <Button Content="الرئيسية"
                        Command="{Binding ShowHomeMenuCommand}"
                        Padding="14,8" Margin="2" FontSize="13" FontWeight="SemiBold"
                        Background="#455A64" Foreground="White"/>
                <Button Content="المرضى"
                        Command="{Binding ShowPatientsMenuCommand}"
                        Padding="14,8" Margin="2" FontSize="13" FontWeight="SemiBold"
                        Background="#1976D2" Foreground="White"/>
                <Button Content="النتائج"
                        Command="{Binding NavigateToTestResultsCommand}"
                        Padding="14,8" Margin="2" FontSize="13" FontWeight="SemiBold"
                        Background="#2E7D32" Foreground="White"/>
                <Button Content="التسليم"
                        Command="{Binding NavigateToDeliveryCommand}"
                        Padding="14,8" Margin="2" FontSize="13" FontWeight="SemiBold"
                        Background="#FF8F00" Foreground="White"/>
                <Button Content="البحث"
                        Command="{Binding NavigateToSearchCommand}"
                        Padding="14,8" Margin="2" FontSize="13" FontWeight="SemiBold"
                        Background="#6A1B9A" Foreground="White"/>

                <Separator Background="#3A5068" Width="1" Margin="4,2"/>

                <Button Content="العينات الخارجية"
                        Command="{Binding ShowExternalSamplesMenuCommand}"
                        Padding="14,8" Margin="2" FontSize="13" FontWeight="SemiBold"
                        Background="#00695C" Foreground="White"/>
                <Button Content="الحسابات"
                        Command="{Binding ShowAccountsMenuCommand}"
                        Padding="14,8" Margin="2" FontSize="13" FontWeight="SemiBold"
                        Background="#4E342E" Foreground="White"/>
                <Button Content="النسخ الاحتياطي"
                        Command="{Binding ShowBackupMenuCommand}"
                        Padding="14,8" Margin="2" FontSize="13" FontWeight="SemiBold"
                        Background="#37474F" Foreground="White"/>

                <Separator Background="#3A5068" Width="1" Margin="4,2"/>

                <Button Content="بيانات التحاليل"
                        Command="{Binding NavigateToTestDataCommand}"
                        Padding="14,8" Margin="2" FontSize="13" FontWeight="SemiBold"
                        Background="#00838F" Foreground="White"/>
                <Button Content="الفئات والمجموعات"
                        Command="{Binding NavigateToCategoriesGroupsCommand}"
                        Padding="14,8" Margin="2" FontSize="13" FontWeight="SemiBold"
                        Background="#00838F" Foreground="White"/>
                <Button Content="النطاقات الطبيعية"
                        Command="{Binding NavigateToNormalRangesCommand}"
                        Padding="14,8" Margin="2" FontSize="13" FontWeight="SemiBold"
                        Background="#00838F" Foreground="White"/>

                <Separator Background="#3A5068" Width="1" Margin="4,2"/>

                <Button Content="إعدادات النظام"
                        Command="{Binding ShowSystemSettingsMenuCommand}"
                        Padding="14,8" Margin="2" FontSize="13" FontWeight="SemiBold"
                        Background="#00838F" Foreground="White"/>
            </ToolBar>
        </ToolBarTray>

        <ContentControl Content="{Binding CurrentView}"/>
    </DockPanel>
</Window>
