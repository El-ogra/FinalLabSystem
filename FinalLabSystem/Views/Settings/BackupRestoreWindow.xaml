<Window x:Class="FinalLabSystem.Views.Settings.BackupRestoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="النسخ الاحتياطي والاستعادة"
        Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft">
    <Window.Resources>
        <Style x:Key="BackupButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <Grid Background="#E3F2FD">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#1565C0">
            <StackPanel Orientation="Horizontal" Margin="8,6">
                <Button Content="إنشاء نسخة احتياطية" Command="{Binding CreateBackupCommand}"
                        Style="{StaticResource BackupButtonStyle}"
                        Background="#1E88E5" Foreground="White"/>
                <Button Content="استعادة" Command="{Binding RestoreCommand}"
                        Style="{StaticResource BackupButtonStyle}"
                        Background="#E53935" Foreground="White"/>
                <Separator Margin="8,0" Background="White"/>
                <Button Content="تصفح المجلد" Command="{Binding BrowseFolderCommand}"
                        Style="{StaticResource BackupButtonStyle}"
                        Background="#FF8F00" Foreground="White"/>
                <Button Content="فتح المجلد" Command="{Binding OpenFolderCommand}"
                        Style="{StaticResource BackupButtonStyle}"
                        Background="#43A047" Foreground="White"/>
                <Separator Margin="8,0" Background="White"/>
                <TextBlock Text="{Binding Backups.Count, StringFormat='عدد النسخ: {0}'}"
                           Foreground="White" VerticalAlignment="Center" Margin="4,0"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Backups}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  AlternatingRowBackground="#F5F5F5"
                  GridLinesVisibility="Horizontal"
                  BorderBrush="#CCC"
                  Margin="8">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="تحديد" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                        Width="60"/>
                <DataGridTextColumn Header="اسم الملف" Binding="{Binding FileName}" Width="*"/>
                <DataGridTextColumn Header="الحجم" Binding="{Binding DisplaySize}" Width="100"/>
                <DataGridTextColumn Header="تاريخ الإنشاء" Binding="{Binding DisplayCreatedAt}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#BBDEFB" Padding="8,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="المجلد:" FontWeight="Bold" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding TargetFolder}" Foreground="#333" Margin="0,0,16,0"/>
                <TextBlock Text="آخر نسخة:" FontWeight="Bold" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding LastBackupAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                           Foreground="#333"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
