<Window x:Class="FinalLabSystem.Views.Settings.ReportSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إعدادات التقارير" Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        Background="#F5F7FA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="إعدادات تنسيق التقارير" FontSize="20" FontWeight="Bold"
                   Foreground="#1A4A52" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Branding -->
                <TextBlock Text="البيانات التعريفية" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                <TextBox Text="{Binding CurrentLayout.LabNameAr, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="0,0,0,8" Padding="6,4"/>
                <TextBox Text="{Binding CurrentLayout.LabNameEn, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="0,0,0,8" Padding="6,4"/>

                <!-- Logo -->
                <TextBlock Text="الشعار" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,8,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBox Text="{Binding CurrentLayout.LogoPath, UpdateSourceTrigger=PropertyChanged}" 
                             Width="300" Padding="6,4" IsReadOnly="True"/>
                    <Button Content="استعراض..." Command="{Binding BrowseLogoCommand}" 
                            Width="80" Margin="8,0,0,0" Padding="6,4"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="العرض (سم):" VerticalAlignment="Center" Width="80"/>
                    <TextBox Text="{Binding CurrentLayout.LogoWidth, UpdateSourceTrigger=PropertyChanged}" 
                             Width="80" Padding="6,4" Margin="8,0,0,0"/>
                    <TextBlock Text="الارتفاع (سم):" VerticalAlignment="Center" Width="80" Margin="16,0,0,0"/>
                    <TextBox Text="{Binding CurrentLayout.LogoHeight, UpdateSourceTrigger=PropertyChanged}" 
                             Width="80" Padding="6,4" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Colors -->
                <TextBlock Text="الألوان" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,8,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="اللون الأساسي:" VerticalAlignment="Center" Width="80"/>
                    <TextBox Text="{Binding CurrentLayout.PrimaryColor, UpdateSourceTrigger=PropertyChanged}" 
                             Width="120" Padding="6,4" Margin="8,0,0,0"/>
                    <TextBlock Text="اللون الثانوي:" VerticalAlignment="Center" Width="80" Margin="16,0,0,0"/>
                    <TextBox Text="{Binding CurrentLayout.SecondaryColor, UpdateSourceTrigger=PropertyChanged}" 
                             Width="120" Padding="6,4" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Typography -->
                <TextBlock Text="الخطوط" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,8,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="الخط الأساسي:" VerticalAlignment="Center" Width="80"/>
                    <TextBox Text="{Binding CurrentLayout.FontFamily, UpdateSourceTrigger=PropertyChanged}" 
                             Width="120" Padding="6,4" Margin="8,0,0,0"/>
                    <TextBlock Text="الحجم:" VerticalAlignment="Center" Width="40" Margin="16,0,0,0"/>
                    <TextBox Text="{Binding CurrentLayout.FontSize, UpdateSourceTrigger=PropertyChanged}" 
                             Width="60" Padding="6,4" Margin="8,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="حجم خط الرأس:" VerticalAlignment="Center" Width="100"/>
                    <TextBox Text="{Binding CurrentLayout.HeaderFontSize, UpdateSourceTrigger=PropertyChanged}" 
                             Width="60" Padding="6,4" Margin="8,0,0,0"/>
                    <TextBlock Text="حجم خط التذييل:" VerticalAlignment="Center" Width="100" Margin="16,0,0,0"/>
                    <TextBox Text="{Binding CurrentLayout.FooterFontSize, UpdateSourceTrigger=PropertyChanged}" 
                             Width="60" Padding="6,4" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Margins -->
                <TextBlock Text="الهوامش (سم)" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,8,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="أعلى:" VerticalAlignment="Center" Width="40"/>
                    <TextBox Text="{Binding CurrentLayout.MarginTop, UpdateSourceTrigger=PropertyChanged}" 
                             Width="60" Padding="6,4" Margin="8,0,0,0"/>
                    <TextBlock Text="أسفل:" VerticalAlignment="Center" Width="40" Margin="16,0,0,0"/>
                    <TextBox Text="{Binding CurrentLayout.MarginBottom, UpdateSourceTrigger=PropertyChanged}" 
                             Width="60" Padding="6,4" Margin="8,0,0,0"/>
                    <TextBlock Text="يمين:" VerticalAlignment="Center" Width="40" Margin="16,0,0,0"/>
                    <TextBox Text="{Binding CurrentLayout.MarginRight, UpdateSourceTrigger=PropertyChanged}" 
                             Width="60" Padding="6,4" Margin="8,0,0,0"/>
                    <TextBlock Text="يسار:" VerticalAlignment="Center" Width="40" Margin="16,0,0,0"/>
                    <TextBox Text="{Binding CurrentLayout.MarginLeft, UpdateSourceTrigger=PropertyChanged}" 
                             Width="60" Padding="6,4" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Visibility -->
                <TextBlock Text="الأقسام" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,8,0,8"/>
                <CheckBox Content="إظهار الرأس" IsChecked="{Binding CurrentLayout.ShowHeader, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                <CheckBox Content="إظهار التذييل" IsChecked="{Binding CurrentLayout.ShowFooter, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                <CheckBox Content="إظهار الختم" IsChecked="{Binding CurrentLayout.ShowStamp, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>

                <!-- Text -->
                <TextBlock Text="النصوص" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,8,0,8"/>
                <TextBox Text="{Binding CurrentLayout.HeaderText, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="0,0,0,8" Padding="6,4"/>
                <TextBox Text="{Binding CurrentLayout.FooterText, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="0,0,0,8" Padding="6,4"/>

                <!-- Page setup -->
                <TextBlock Text="إعدادات الصفحة" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,8,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="الاتجاه:" VerticalAlignment="Center" Width="60"/>
                    <TextBox Text="{Binding CurrentLayout.PageOrientation, UpdateSourceTrigger=PropertyChanged}" 
                             Width="80" Padding="6,4" Margin="8,0,0,0"/>
                    <TextBlock Text="الحجم:" VerticalAlignment="Center" Width="40" Margin="16,0,0,0"/>
                    <TextBox Text="{Binding CurrentLayout.PaperSize, UpdateSourceTrigger=PropertyChanged}" 
                             Width="80" Padding="6,4" Margin="8,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
            <Button Content="حفظ" Command="{Binding SaveCommand}" 
                    Width="100" Height="36" FontSize="14" Margin="8,0"
                    Background="#1976D2" Foreground="White"/>
            <Button Content="إعادة الافتراضي" Command="{Binding ResetToDefaultsCommand}" 
                    Width="120" Height="36" FontSize="14" Margin="8,0"
                    Background="#E65100" Foreground="White"/>
            <Button Content="معاينة" Command="{Binding PreviewCommand}" 
                    Width="100" Height="36" FontSize="14" Margin="8,0"
                    Background="#455A64" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
