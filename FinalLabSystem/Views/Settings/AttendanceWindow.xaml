<Window x:Class="FinalLabSystem.Views.Settings.AttendanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إدارة الحضور والانصراف"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft">
    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <Grid Background="#E3F2FD">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#1565C0">
            <StackPanel Orientation="Horizontal" Margin="8,6">
                <Button Content="تسجيل دخول" Command="{Binding ClockInCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#43A047" Foreground="White"/>
                <Button Content="تسجيل خروج" Command="{Binding ClockOutCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#E53935" Foreground="White"/>
                <Button Content="تحديث" Command="{Binding RefreshCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#1E88E5" Foreground="White"/>
                <Button Content="إضافة وردية" Command="{Binding SaveShiftCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#FF8F00" Foreground="White"/>
                <Separator Margin="8,0" Background="White"/>
                <TextBlock Text="التاريخ:" Foreground="White" VerticalAlignment="Center" Margin="4,0"/>
                <DatePicker SelectedDate="{Binding SelectedDate, Converter={StaticResource DateOnlyConverter}}"
                            Width="160" Height="28" Margin="4"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <TabControl Grid.Row="1" Margin="8">
            <!-- Tab 1: Attendance Records -->
            <TabItem Header="سجلات الحضور">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Staff + Shift Selection -->
                    <Border Grid.Row="0" Background="White" BorderBrush="#CCC" BorderThickness="1"
                            CornerRadius="4" Margin="4" Padding="8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="الموظف:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Bold"/>
                            <ComboBox ItemsSource="{Binding StaffList}"
                                      SelectedItem="{Binding SelectedStaff}"
                                      DisplayMemberPath="DisplayName"
                                      Width="200" Height="28" VerticalAlignment="Center"/>

                            <TextBlock Text="الوردية:" VerticalAlignment="Center" Margin="20,0,8,0" FontWeight="Bold"/>
                            <ComboBox ItemsSource="{Binding WorkShifts}"
                                      SelectedItem="{Binding SelectedShift}"
                                      DisplayMemberPath="ShiftName"
                                      Width="200" Height="28" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Attendance DataGrid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Attendances}"
                              SelectedItem="{Binding SelectedAttendance}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              AlternatingRowBackground="#F5F5F5"
                              GridLinesVisibility="Horizontal"
                              BorderBrush="#CCC"
                              Margin="4">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="الموظف" Binding="{Binding StaffName}" Width="150"/>
                            <DataGridTextColumn Header="الوردية" Binding="{Binding ShiftName}" Width="120"/>
                            <DataGridTextColumn Header="تاريخ الحضور" Binding="{Binding AttendanceDate, StringFormat=yyyy/MM/dd}" Width="120"/>
                            <DataGridTextColumn Header="وقت الدخول" Binding="{Binding ClockInTime}" Width="80"/>
                            <DataGridTextColumn Header="وقت الخروج" Binding="{Binding ClockOutTime}" Width="80"/>
                            <DataGridTextColumn Header="التأخير (د)" Binding="{Binding LateMinutes}" Width="80"/>
                            <DataGridTextColumn Header="الساعات" Binding="{Binding HoursWorkedDisplay}" Width="80"/>
                            <DataGridCheckBoxColumn Header="نشط" Binding="{Binding IsClockedIn, Mode=OneWay}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Tab 2: Work Shifts -->
            <TabItem Header="الورديات">
                <DataGrid ItemsSource="{Binding WorkShifts}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          AlternatingRowBackground="#F5F5F5"
                          GridLinesVisibility="Horizontal"
                          BorderBrush="#CCC"
                          Margin="8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="اسم الوردية" Binding="{Binding ShiftName}" Width="200"/>
                        <DataGridTextColumn Header="وقت الدخول" Binding="{Binding ClockInDisplay}" Width="120"/>
                        <DataGridTextColumn Header="وقت الخروج" Binding="{Binding ClockOutDisplay}" Width="120"/>
                        <DataGridCheckBoxColumn Header="نشطة" Binding="{Binding IsActive}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#1565C0" Padding="8,4">
            <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="12"/>
        </Border>
    </Grid>
</Window>
