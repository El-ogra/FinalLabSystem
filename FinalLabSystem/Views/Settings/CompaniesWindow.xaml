<Window x:Class="FinalLabSystem.Views.Settings.CompaniesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft">
    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="90"/>
        </Style>
        <Style x:Key="FieldTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="FieldComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Background="#E3F2FD" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#1565C0">
            <StackPanel Orientation="Horizontal" Margin="8,6">
                <Button Content="إضافة شركة" Command="{Binding AddCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#43A047" Foreground="White"/>
                <Button Content="حفظ" Command="{Binding SaveCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#1E88E5" Foreground="White"/>
                <Button Content="إلغاء" Command="{Binding CancelCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#757575" Foreground="White"/>
                <Button Content="تحديث" Command="{Binding RefreshCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#FB8C00" Foreground="White"/>
                <Button Content="تعطيل" Command="{Binding DeleteCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#E53935" Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- Company List -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Companies}"
                  SelectedItem="{Binding SelectedCompany}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  Background="White"
                  Margin="6,4,6,4"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="م" Binding="{Binding CompanyId}" Width="40"/>
                <DataGridTextColumn Header="اسم الشركة" Binding="{Binding CompanyName}" Width="180"/>
                <DataGridTextColumn Header="النوع" Binding="{Binding CompanyType}" Width="100"/>
                <DataGridTextColumn Header="جهة الاتصال" Binding="{Binding ContactPerson}" Width="140"/>
                <DataGridTextColumn Header="الهاتف" Binding="{Binding Phone}" Width="100"/>
                <DataGridTextColumn Header="البريد" Binding="{Binding Email}" Width="140"/>
                <DataGridCheckBoxColumn Header="نشط" Binding="{Binding IsActive}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Edit Panel -->
        <Border Grid.Row="2" Background="White" BorderBrush="#BBDEFB" BorderThickness="1" Margin="6,0,6,6">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                <Grid Margin="8" DataContext="{Binding EditModel}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: CompanyName + CompanyType -->
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="اسم الشركة" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldTextBox}"
                             Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="النوع" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldComboBox}"
                              SelectedItem="{Binding CompanyType}">
                        <ComboBoxItem Content="CORPORATE"/>
                        <ComboBoxItem Content="INDIVIDUAL"/>
                    </ComboBox>

                    <!-- Row 1: ContactPerson + Phone -->
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="جهة الاتصال" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldTextBox}"
                             Text="{Binding ContactPerson, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="1" Grid.Column="1" Text="الهاتف" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldTextBox}"
                             Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Row 2: Phone2 + Email -->
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="هاتف 2" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldTextBox}"
                             Text="{Binding Phone2, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="2" Grid.Column="1" Text="البريد الإلكتروني" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldTextBox}"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Row 3: Address (span 2 columns) -->
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="العنوان" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource FieldTextBox}"
                             Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Row 4: DiscountRate + CreditLimit -->
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="نسبة الخصم (%)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Row="4" Grid.Column="0" Style="{StaticResource FieldTextBox}"
                             Text="{Binding DiscountRate, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="4" Grid.Column="1" Text="الحد الائتماني" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Row="4" Grid.Column="0" Style="{StaticResource FieldTextBox}"
                             Text="{Binding CreditLimit, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Row 5: PaymentTerms + IsActive -->
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="شروط الدفع" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Row="5" Grid.Column="0" Style="{StaticResource FieldTextBox}"
                             Text="{Binding PaymentTerms, UpdateSourceTrigger=PropertyChanged}"/>

                    <CheckBox Grid.Row="5" Grid.Column="1" Content="نشط"
                              IsChecked="{Binding IsActive}"
                              Margin="4,4,0,4" VerticalAlignment="Center"/>

                    <!-- Row 6: ContractStartDate + ContractEndDate -->
                    <TextBlock Grid.Row="6" Grid.Column="1" Text="بداية العقد (yyyy-mm-dd)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Row="6" Grid.Column="0" Style="{StaticResource FieldTextBox}"
                             Text="{Binding ContractStartDate, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="6" Grid.Column="1" Text="نهاية العقد (yyyy-mm-dd)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Row="6" Grid.Column="0" Style="{StaticResource FieldTextBox}"
                             Text="{Binding ContractEndDate, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Row 7: BillingPeriodicity + Notes -->
                    <TextBlock Grid.Row="7" Grid.Column="1" Text="دورة الفوترة" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Grid.Row="7" Grid.Column="0" Style="{StaticResource FieldComboBox}"
                              SelectedItem="{Binding BillingPeriodicity}">
                        <ComboBoxItem Content="Monthly"/>
                        <ComboBoxItem Content="Quarterly"/>
                    </ComboBox>

                    <TextBlock Grid.Row="7" Grid.Column="1" Text="ملاحظات" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Row="7" Grid.Column="0" Style="{StaticResource FieldTextBox}"
                             Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
