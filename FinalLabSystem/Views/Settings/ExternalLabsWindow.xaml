<Window x:Class="FinalLabSystem.Views.Settings.ExternalLabsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="المعامل الخارجية" Height="700" Width="1100"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterOwner"
        Background="#FFF5F5F5">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="المعامل الخارجية و الشحنات" FontSize="22" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,12" Foreground="#FF1A237E"/>

        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}">

            <!-- Tab 1: Labs -->
            <TabItem Header="المعامل">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="6"
                            Background="White" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="قائمة المعامل" FontSize="16" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="تحديث" Command="{Binding RefreshLabsCommand}"
                                        Padding="12,4" Background="#FFE3F2FD" Foreground="#FF1565C0"
                                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding Labs}"
                                      SelectedItem="{Binding SelectedLab}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      BorderThickness="0"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      AlternatingRowBackground="#FFF8F9FA"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="رقم" Binding="{Binding ExternalLabId}" Width="50"/>
                                    <DataGridTextColumn Header="اسم المختبر" Binding="{Binding LabName}" Width="*"/>
                                    <DataGridTextColumn Header="جهة الاتصال" Binding="{Binding ContactPerson}" Width="100"/>
                                    <DataGridTextColumn Header="الهاتف" Binding="{Binding Phone}" Width="100"/>
                                    <DataGridTextColumn Header="البريد" Binding="{Binding Email}" Width="120"/>
                                    <DataGridCheckBoxColumn Header="نشط" Binding="{Binding IsActive}" Width="50"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center"
                                  VerticalAlignment="Stretch" Background="Transparent"/>

                    <Border Grid.Column="2" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="6"
                            Background="White" Padding="12">
                        <StackPanel>
                            <TextBlock Text="إضافة مختبر جديد" FontSize="15" FontWeight="Bold"
                                       Margin="0,0,0,8" Foreground="#FF1A237E"/>

                            <TextBlock Text="اسم المختبر:" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditLabName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8" Padding="6,4"/>

                            <TextBlock Text="جهة الاتصال:" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditContactPerson, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8" Padding="6,4"/>

                            <TextBlock Text="الهاتف:" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditPhone, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8" Padding="6,4"/>

                            <TextBlock Text="البريد الإلكتروني:" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditEmail, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8" Padding="6,4"/>

                            <TextBlock Text="العنوان:" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditAddress, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8" Padding="6,4"/>

                            <TextBlock Text="ملاحظات:" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12" Padding="6,4"/>

                            <Button Content="إضافة مختبر"
                                    Command="{Binding CreateLabCommand}"
                                    Background="#FF1A237E" Foreground="White"
                                    FontWeight="Bold" Padding="16,8"
                                    BorderThickness="0" Cursor="Hand"
                                    HorizontalAlignment="Stretch"
                                    IsEnabled="{Binding CanCreateLab}"
                                    Margin="0,0,0,8"/>

                            <Button Content="حذف مختبر (تعطيل)"
                                    Command="{Binding DeleteLabCommand}"
                                    Background="#FFC62828" Foreground="White"
                                    FontWeight="Bold" Padding="16,8"
                                    BorderThickness="0" Cursor="Hand"
                                    HorizontalAlignment="Stretch"
                                    IsEnabled="{Binding CanDeleteLab}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 2: Pending Shipments -->
            <TabItem Header="الشحنات المعلقة">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="6"
                            Background="White" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="الشحنات" FontSize="16" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="تحديث" Command="{Binding RefreshShipmentsCommand}"
                                        Padding="12,4" Background="#FFE3F2FD" Foreground="#FF1565C0"
                                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding Shipments}"
                                      SelectedItem="{Binding SelectedShipment}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      BorderThickness="0"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      AlternatingRowBackground="#FFF8F9FA"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="رقم الشحنة" Binding="{Binding ShipmentId}" Width="70"/>
                                    <DataGridTextColumn Header="المختبر" Binding="{Binding LabName}" Width="*"/>
                                    <DataGridTextColumn Header="التاريخ" Binding="{Binding ShipmentDate, StringFormat=yyyy/MM/dd}" Width="90"/>
                                    <DataGridTextColumn Header="الحالة" Binding="{Binding Status}" Width="80"/>
                                    <DataGridTextColumn Header="رقم التتبع" Binding="{Binding TrackingNumber}" Width="150"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 3: Send Manifest -->
            <TabItem Header="إرسال شحنة">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="6"
                            Background="White" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="العناصر المعلقة للإرسال" FontSize="16" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="تحميل" Command="{Binding LoadPendingCommand}"
                                        Padding="12,4" Background="#FFE3F2FD" Foreground="#FF1565C0"
                                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding PendingItems}"
                                      AutoGenerateColumns="False"
                                      BorderThickness="0"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      AlternatingRowBackground="#FFF8F9FA"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="اختيار" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                                    <DataGridTextColumn Header="رقم الزيارة" Binding="{Binding VisitTestId}" Width="70"/>
                                    <DataGridTextColumn Header="التحليل" Binding="{Binding TestName}" Width="*"/>
                                    <DataGridTextColumn Header="المريض" Binding="{Binding PatientName}" Width="120"/>
                                    <DataGridTextColumn Header="الحالة" Binding="{Binding Status}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Button Grid.Row="2"
                                    Content="إرسال شحنة"
                                    Command="{Binding SendManifestCommand}"
                                    Background="#FF2E7D32" Foreground="White"
                                    FontWeight="Bold" Padding="16,8"
                                    BorderThickness="0" Cursor="Hand"
                                    HorizontalAlignment="Right"
                                    IsEnabled="{Binding CanSendManifest}"
                                    Margin="0,8,0,0"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 4: Receive Results -->
            <TabItem Header="استلام النتائج">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="6"
                            Background="White" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="عناصر معلقة لاستلام النتائج" FontSize="16" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="تحميل" Command="{Binding LoadPendingCommand}"
                                        Padding="12,4" Background="#FFE3F2FD" Foreground="#FF1565C0"
                                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding PendingItems}"
                                      SelectedItem="{Binding SelectedPendingItem}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      BorderThickness="0"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      AlternatingRowBackground="#FFF8F9FA"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="رقم" Binding="{Binding ShipmentItemId}" Width="50"/>
                                    <DataGridTextColumn Header="التحليل" Binding="{Binding TestName}" Width="*"/>
                                    <DataGridTextColumn Header="المريض" Binding="{Binding PatientName}" Width="120"/>
                                    <DataGridTextColumn Header="الحالة" Binding="{Binding Status}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center"
                                  VerticalAlignment="Stretch" Background="Transparent"/>

                    <Border Grid.Column="2" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="6"
                            Background="White" Padding="12">
                        <StackPanel>
                            <TextBlock Text="استلام النتيجة" FontSize="15" FontWeight="Bold"
                                       Margin="0,0,0,8" Foreground="#FF1A237E"/>

                            <TextBlock Text="قيمة النتيجة:" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ReceiveResultValue, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12" Padding="6,4"/>

                            <Button Content="تسجيل الاستلام"
                                    Command="{Binding ReceiveResultsCommand}"
                                    Background="#FF2E7D32" Foreground="White"
                                    FontWeight="Bold" Padding="16,8"
                                    BorderThickness="0" Cursor="Hand"
                                    HorizontalAlignment="Stretch"
                                    IsEnabled="{Binding CanReceiveResults}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="#FFE3F2FD" CornerRadius="0,0,6,6" Padding="12,6" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#FF1565C0"/>
        </Border>
    </Grid>
</Window>
