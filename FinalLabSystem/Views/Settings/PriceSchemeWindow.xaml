<Window x:Class="FinalLabSystem.Views.Settings.PriceSchemeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Height="650"
        Width="1000"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft">
    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="90"/>
        </Style>
        <Style x:Key="FieldTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Background="#E3F2FD" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#1565C0">
            <StackPanel Orientation="Horizontal" Margin="8,6">
                <Button Content="إضافة مخطط" Command="{Binding AddCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#43A047" Foreground="White"/>
                <Button Content="حفظ" Command="{Binding SaveCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#1E88E5" Foreground="White"/>
                <Button Content="إلغاء" Command="{Binding CancelCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#757575" Foreground="White"/>
                <Button Content="تحديث" Command="{Binding RefreshCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#FB8C00" Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- Scheme List -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Schemes}"
                  SelectedItem="{Binding SelectedScheme}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  Background="White"
                  Margin="6,4,6,4"
                  HeadersVisibility="Column"
                  MinHeight="120">
            <DataGrid.Columns>
                <DataGridTextColumn Header="م" Binding="{Binding SchemeId}" Width="40"/>
                <DataGridTextColumn Header="اسم المخطط" Binding="{Binding SchemeName}" Width="200"/>
                <DataGridTextColumn Header="الوصف" Binding="{Binding Description}" Width="250"/>
                <DataGridCheckBoxColumn Header="افتراضي" Binding="{Binding IsDefault}" Width="70"/>
                <DataGridCheckBoxColumn Header="نشط" Binding="{Binding IsActive}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Edit Panel (visible when editing) -->
        <Border Grid.Row="2" Background="White" BorderBrush="#BBDEFB" BorderThickness="1" Margin="6,0,6,4"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
            <StackPanel Margin="12,8" Orientation="Horizontal">
                <TextBlock Text="اسم المخطط" Style="{StaticResource FieldLabel}"/>
                <TextBox Width="200" Style="{StaticResource FieldTextBox}"
                         Text="{Binding EditModel.SchemeName, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="الوصف" Style="{StaticResource FieldLabel}" Margin="16,0,0,0"/>
                <TextBox Width="200" Style="{StaticResource FieldTextBox}"
                         Text="{Binding EditModel.Description, UpdateSourceTrigger=PropertyChanged}"/>
                <CheckBox Content="افتراضي" IsChecked="{Binding EditModel.IsDefault}" Margin="12,0"/>
                <CheckBox Content="نشط" IsChecked="{Binding EditModel.IsActive}" Margin="12,0"/>
            </StackPanel>
        </Border>

        <!-- Prices Header -->
        <Border Grid.Row="3" Background="#1565C0" Margin="6,0,6,0">
            <StackPanel Orientation="Horizontal" Margin="8,4">
                <TextBlock Text="أسعار التحاليل للمخطط المحدد" Foreground="White" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                <Button Content="حفظ الأسعار" Command="{Binding SavePricesCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#43A047" Foreground="White" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Prices DataGrid -->
        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding TestPrices}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  Background="White"
                  Margin="6,0,6,6"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="كود التحليل" Binding="{Binding TypeCode}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="اسم التحليل" Binding="{Binding TypeName}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="السعر" Binding="{Binding Price, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
