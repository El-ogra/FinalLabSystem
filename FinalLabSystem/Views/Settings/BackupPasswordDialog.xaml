<Window x:Class="FinalLabSystem.Views.Settings.BackupPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="أدخل كلمة المرور"
        Height="280" Width="380"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="أدخل كلمة المرور"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,12"
                   HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="1" Text="كلمة المرور:"
                   FontSize="12" Foreground="#666" Margin="0,0,0,4"/>

        <PasswordBox Grid.Row="2" x:Name="PasswordBox"
                     Height="30" Margin="0,0,0,8"
                     KeyDown="PasswordBox_KeyDown"/>

        <TextBlock Grid.Row="3" Text="تأكيد كلمة المرور:"
                   FontSize="12" Foreground="#666" Margin="0,0,0,4"/>

        <PasswordBox Grid.Row="4" x:Name="ConfirmPasswordBox"
                     Height="30" Margin="0,0,0,8"
                     KeyDown="PasswordBox_KeyDown"/>

        <TextBlock Grid.Row="5" x:Name="ErrorText"
                   Foreground="Red" FontSize="12"
                   Visibility="Collapsed" Margin="0,0,0,8"
                   HorizontalAlignment="Center"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,12,0,0">
            <Button Content="تأكيد" Click="OK_Click"
                    Width="80" Height="30" Margin="8,0"
                    Background="#1976D2" Foreground="White" FontWeight="Bold"/>
            <Button Content="إلغاء" Click="Cancel_Click"
                    Width="80" Height="30" Margin="8,0"
                    Background="#E53935" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
