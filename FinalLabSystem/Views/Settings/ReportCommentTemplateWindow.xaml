<Window x:Class="FinalLabSystem.Views.Settings.ReportCommentTemplateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إدارة قوالب التعليقات"
        Width="1100"
        Height="780"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="102"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Background" Value="#A8E000"/>
            <Setter Property="Foreground" Value="#001A20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,4"/>
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#123A42"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Margin" Value="0,10,0,6"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F7FA" Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="قوالب التعليقات التلقائية" Style="{StaticResource SectionHeaderStyle}"/>

        <!-- Main content: list + detail -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40*"/>
                <ColumnDefinition Width="60*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Template list -->
            <Border Grid.Column="0" Background="White" BorderBrush="#CFD8DC" BorderThickness="1" Padding="8" Margin="0,0,6,0">
                <DataGrid ItemsSource="{Binding Templates}"
                          SelectedItem="{Binding SelectedTemplate}"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="الترتيب" Binding="{Binding SortOrder}" Width="60"/>
                        <DataGridTextColumn Header="العنوان" Binding="{Binding Title}" Width="*"/>
                        <DataGridTextColumn Header="اللغة" Binding="{Binding CommentLang}" Width="50"/>
                        <DataGridTextColumn Header="المحفّز" Binding="{Binding TriggerCondition}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Right: Template detail -->
            <Border Grid.Column="1" Background="White" BorderBrush="#CFD8DC" BorderThickness="1" Padding="10" Margin="6,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="العنوان"/>
                        <TextBox Text="{Binding EditableTitle, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="التعليق"/>
                        <TextBox Text="{Binding EditableCommentText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>

                        <TextBlock Text="اللغة"/>
                        <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                  SelectedItem="{Binding EditableCommentLang}"/>

                        <TextBlock Text="المحفّز (Trigger)"/>
                        <ComboBox ItemsSource="{Binding AvailableTriggers}"
                                  SelectedItem="{Binding EditableTriggerCondition}"/>

                        <TextBlock Text="الفئة"/>
                        <ComboBox ItemsSource="{Binding AvailableCategories}"
                                  SelectedValuePath="CategoryId"
                                  DisplayMemberPath="CategoryNameEn"
                                  SelectedValue="{Binding EditableCategoryId, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="نوع التحليل"/>
                        <ComboBox ItemsSource="{Binding AvailableTestTypes}"
                                  SelectedValuePath="TestTypeId"
                                  DisplayMemberPath="TestTypeNameEn"
                                  SelectedValue="{Binding EditableTesttypeId, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="المكوّن"/>
                        <ComboBox ItemsSource="{Binding AvailableComponents}"
                                  SelectedValuePath="ComponentId"
                                  DisplayMemberPath="ComponentNameEn"
                                  SelectedValue="{Binding EditableComponentId, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="ترتيب الفرز"/>
                        <TextBox Text="{Binding EditableSortOrder, UpdateSourceTrigger=PropertyChanged}"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,12,0,0">
                            <Button Content="جديد" Command="{Binding NewCommand}" Style="{StaticResource ActionButtonStyle}"/>
                            <Button Content="حفظ" Command="{Binding SaveCommand}" Style="{StaticResource ActionButtonStyle}" Background="#8BC34A"/>
                            <Button Content="حذف" Command="{Binding DeleteCommand}" Style="{StaticResource ActionButtonStyle}" Background="#F44336"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Bottom toolbar -->
        <Border Grid.Row="2" Background="#123A42" Padding="8" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="تحديث" Command="{Binding RefreshCommand}" Style="{StaticResource ActionButtonStyle}"/>
                <Button Content="إغلاق" Command="{Binding CloseCommand}" Style="{StaticResource ActionButtonStyle}" CommandParameter="{RelativeSource AncestorType=Window}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
