<Window x:Class="FinalLabSystem.Views.Settings.ContractInvoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="إدارة فواتير العقود" Height="700" Width="1100"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterOwner"
        Background="#FFF5F5F5">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="إدارة فواتير العقود" FontSize="22" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,12" Foreground="#FF1A237E"/>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Invoices List -->
            <Border Grid.Column="0" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="6"
                    Background="White" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="فواتير العقود" FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Content="تحديث" Command="{Binding RefreshCommand}"
                                Padding="12,4" Background="#FFE3F2FD" Foreground="#FF1565C0"
                                FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Invoices}"
                              SelectedItem="{Binding SelectedInvoice}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              AlternatingRowBackground="#FFF8F9FA"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="رقم" Binding="{Binding ContractInvoiceId}" Width="50"/>
                            <DataGridTextColumn Header="الشركة" Binding="{Binding CompanyName}" Width="*"/>
                            <DataGridTextColumn Header="التاريخ" Binding="{Binding InvoiceDate, StringFormat=yyyy/MM/dd}" Width="90"/>
                            <DataGridTextColumn Header="من" Binding="{Binding PeriodStart, StringFormat=yyyy/MM/dd}" Width="80"/>
                            <DataGridTextColumn Header="إلى" Binding="{Binding PeriodEnd, StringFormat=yyyy/MM/dd}" Width="80"/>
                            <DataGridTextColumn Header="المبلغ" Binding="{Binding TotalAmount, StringFormat=N2}" Width="90"/>
                            <DataGridTextColumn Header="المدفوع" Binding="{Binding PaidAmount, StringFormat=N2}" Width="90"/>
                            <DataGridTextColumn Header="الحالة" Binding="{Binding Status}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="Transparent"/>

            <!-- Right: Actions -->
            <Border Grid.Column="2" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="6"
                    Background="White" Padding="12">
                <StackPanel>

                    <!-- Generate Invoice Section -->
                    <TextBlock Text="إنشاء فاتورة جديدة" FontSize="15" FontWeight="Bold"
                               Margin="0,0,0,8" Foreground="#FF1A237E"/>

                    <TextBlock Text="الشركة:" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Companies}"
                              SelectedItem="{Binding SelectedCompany}"
                              DisplayMemberPath="CompanyName"
                              Margin="0,0,0,8" Padding="6,4"/>

                    <TextBlock Text="من تاريخ:" Margin="0,0,0,4"/>
                    <DatePicker SelectedDate="{Binding PeriodStart}" Margin="0,0,0,8" Padding="6,4"/>

                    <TextBlock Text="إلى تاريخ:" Margin="0,0,0,4"/>
                    <DatePicker SelectedDate="{Binding PeriodEnd}" Margin="0,0,0,12" Padding="6,4"/>

                    <Button Content="إنشاء فاتورة"
                            Command="{Binding GenerateInvoiceCommand}"
                            Background="#FF1A237E" Foreground="White"
                            FontWeight="Bold" Padding="16,8"
                            BorderThickness="0" Cursor="Hand"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{Binding CanGenerateInvoice}"
                            Margin="0,0,0,16"/>

                    <!-- Divider -->
                    <Separator Margin="0,0,0,16"/>

                    <!-- Record Payment Section -->
                    <TextBlock Text="تسجيل دفعة" FontSize="15" FontWeight="Bold"
                               Margin="0,0,0,8" Foreground="#FF1A237E"/>

                    <TextBlock Text="المبلغ:" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8" Padding="6,4"/>

                    <TextBlock Text="طريقة الدفع:" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PaymentMethod, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8" Padding="6,4"/>

                    <TextBlock Text="رقم المرجع:" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PaymentReference, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12" Padding="6,4"/>

                    <Button Content="تسجيل الدفعة"
                            Command="{Binding RecordPaymentCommand}"
                            Background="#FF2E7D32" Foreground="White"
                            FontWeight="Bold" Padding="16,8"
                            BorderThickness="0" Cursor="Hand"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{Binding CanRecordPayment}"
                            Margin="0,0,0,12"/>

                    <!-- Payments List for Selected Invoice -->
                    <TextBlock Text="الدفعات:" FontSize="14" FontWeight="Bold"
                               Margin="0,8,0,6"/>

                    <DataGrid ItemsSource="{Binding Payments}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              AlternatingRowBackground="#FFF8F9FA"
                              CanUserAddRows="False"
                              MaxHeight="200">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="التاريخ" Binding="{Binding PaymentDate, StringFormat=yyyy/MM/dd}" Width="80"/>
                            <DataGridTextColumn Header="المبلغ" Binding="{Binding Amount, StringFormat=N2}" Width="70"/>
                            <DataGridTextColumn Header="الطريقة" Binding="{Binding PaymentMethod}" Width="70"/>
                            <DataGridTextColumn Header="المرجع" Binding="{Binding ReferenceNumber}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                </StackPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#FFE3F2FD" CornerRadius="0,0,6,6" Padding="12,6" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#FF1565C0"/>
        </Border>
    </Grid>
</Window>
