<Window x:Class="FinalLabSystem.Views.Settings.InventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إدارة المخزون"
        Height="650" Width="1000"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft">
    <Window.Resources>
        <Style x:Key="InvButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <Grid Background="#E8F5E9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#2E7D32">
            <StackPanel Orientation="Horizontal" Margin="8,6">
                <Button Content="تحديث" Command="{Binding RefreshCommand}"
                        Style="{StaticResource InvButtonStyle}"
                        Background="#43A047" Foreground="White"/>
                <Separator Margin="8,0" Background="White"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="White"
                           VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <!-- Materials Table -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Materials}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  AlternatingRowBackground="#F1F8E9"
                  GridLinesVisibility="Horizontal"
                  BorderBrush="#CCC"
                  Margin="8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="الاسم" Binding="{Binding MaterialName}" Width="*"/>
                <DataGridTextColumn Header="الاسم العربي" Binding="{Binding MaterialNameAr}" Width="*"/>
                <DataGridTextColumn Header="اللون" Binding="{Binding TubeColor}" Width="80"/>
                <DataGridTextColumn Header="المخزون الحالي" Binding="{Binding CurrentStock}" Width="120"/>
                <DataGridTextColumn Header="الحد الأدنى" Binding="{Binding MinimumStock}" Width="100"/>
                <DataGridTemplateColumn Header="الحالة" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding IsLowStock, Converter={StaticResource LowStockTextConverter}}"
                                       Foreground="{Binding IsLowStock, Converter={StaticResource LowStockBrushConverter}}"
                                       FontWeight="Bold" HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="تعديل" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="تعديل"
                                    Command="{Binding AdjustStockCommand}"
                                    CommandParameter="{Binding}"
                                    Background="#FF8F00" Foreground="White"
                                    Padding="8,2" FontWeight="Bold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#C8E6C9" Padding="8,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="عدد الأنواع:" FontWeight="Bold" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding Materials.Count}" Margin="0,0,16,0"/>
                <TextBlock Text="منخفض المخزون:" FontWeight="Bold" Foreground="#D32F2F" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding LowStockCount}" Foreground="#D32F2F" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
