<Window x:Class="FinalLabSystem.Views.Settings.CategoriesGroupsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إدارة الفئات والمجموعات"
        Width="1100"
        Height="780"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="102"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Background" Value="#A8E000"/>
            <Setter Property="Foreground" Value="#001A20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,4"/>
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#123A42"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Margin" Value="0,10,0,6"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F7FA" Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="1" VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- UPPER SECTION - الفئات -->
            <Grid Grid.Row="0" Margin="0,0,0,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="الفئات" Style="{StaticResource SectionHeaderStyle}"/>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40*"/>
                        <ColumnDefinition Width="60*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="White" BorderBrush="#CFD8DC" BorderThickness="1" Padding="8" Margin="0,0,6,0">
                        <DataGrid ItemsSource="{Binding CategoryList.AllCategories}"
                                  SelectedItem="{Binding CategoryList.SelectedCategory}"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="الترتيب" Binding="{Binding SortOrder}" Width="70"/>
                                <DataGridTextColumn Header="رمز الفئة" Binding="{Binding CategoryCode}" Width="100"/>
                                <DataGridTextColumn Header="الاسم (إنجليزي)" Binding="{Binding CategoryNameEn}" Width="*"/>
                                <DataGridTextColumn Header="الاسم (عربي)" Binding="{Binding CategoryNameAr}" Width="*"/>
                                <DataGridCheckBoxColumn Header="نشط" Binding="{Binding IsActive, Mode=OneWay}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                    <Border Grid.Column="1" Background="White" BorderBrush="#CFD8DC" BorderThickness="1" Padding="10" Margin="6,0,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="رمز الفئة"/>
                                <TextBox Text="{Binding CategoryDetail.EditableCategoryCode, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="الاسم (إنجليزي)"/>
                                <TextBox Text="{Binding CategoryDetail.EditableCategoryNameEn, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="الاسم (عربي)"/>
                                <TextBox Text="{Binding CategoryDetail.EditableCategoryNameAr, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="ترتيب الفرز"/>
                                <TextBox Text="{Binding CategoryDetail.EditableSortOrder, UpdateSourceTrigger=PropertyChanged}"/>
                                <CheckBox Content="نشط" IsChecked="{Binding CategoryDetail.EditableIsActive, UpdateSourceTrigger=PropertyChanged}" Margin="8,4"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,8,0,0">
                                    <Button Content="جديد" Command="{Binding NewCategoryCommand}" Style="{StaticResource ActionButtonStyle}"/>
                                    <Button Content="حفظ" Command="{Binding SaveCategoryCommand}" Style="{StaticResource ActionButtonStyle}" Background="#8BC34A"/>
                                    <Button Content="حذف" Command="{Binding DeleteCategoryCommand}" Style="{StaticResource ActionButtonStyle}" Background="#F44336"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Row="1" Height="1" Background="#E0E0E0" Margin="0,10"/>

            <!-- LOWER SECTION - المجموعات -->
            <Grid Grid.Row="2" Margin="0,4,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="المجموعات" Style="{StaticResource SectionHeaderStyle}"/>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40*"/>
                        <ColumnDefinition Width="60*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="White" BorderBrush="#CFD8DC" BorderThickness="1" Padding="8" Margin="0,0,6,0">
                        <DataGrid ItemsSource="{Binding GroupList.AllGroups}"
                                  SelectedItem="{Binding GroupList.SelectedGroup}"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="الترتيب" Binding="{Binding SortOrder}" Width="70"/>
                                <DataGridTextColumn Header="رمز المجموعة" Binding="{Binding GroupCode}" Width="100"/>
                                <DataGridTextColumn Header="الاسم (إنجليزي)" Binding="{Binding GroupNameEn}" Width="*"/>
                                <DataGridTextColumn Header="الاسم (عربي)" Binding="{Binding GroupNameAr}" Width="*"/>
                                <DataGridCheckBoxColumn Header="نشط" Binding="{Binding IsActive, Mode=OneWay}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                    <Border Grid.Column="1" Background="White" BorderBrush="#CFD8DC" BorderThickness="1" Padding="10" Margin="6,0,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="الفئة"/>
                                <ComboBox ItemsSource="{Binding GroupDetail.AvailableCategories}"
                                          SelectedValuePath="CategoryId"
                                          DisplayMemberPath="CategoryNameEn"
                                          SelectedValue="{Binding GroupDetail.EditableSelectedCategoryId, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="رمز المجموعة"/>
                                <TextBox Text="{Binding GroupDetail.EditableGroupCode, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="الاسم (إنجليزي)"/>
                                <TextBox Text="{Binding GroupDetail.EditableGroupNameEn, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="الاسم (عربي)"/>
                                <TextBox Text="{Binding GroupDetail.EditableGroupNameAr, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="ترتيب الفرز"/>
                                <TextBox Text="{Binding GroupDetail.EditableSortOrder, UpdateSourceTrigger=PropertyChanged}"/>
                                <CheckBox Content="نشط" IsChecked="{Binding GroupDetail.EditableIsActive, UpdateSourceTrigger=PropertyChanged}" Margin="8,4"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,8,0,0">
                                    <Button Content="جديد" Command="{Binding NewGroupCommand}" Style="{StaticResource ActionButtonStyle}"/>
                                    <Button Content="حفظ" Command="{Binding SaveGroupCommand}" Style="{StaticResource ActionButtonStyle}" Background="#8BC34A"/>
                                    <Button Content="حذف" Command="{Binding DeleteGroupCommand}" Style="{StaticResource ActionButtonStyle}" Background="#F44336"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- Bottom toolbar -->
        <Border Grid.Row="2" Background="#123A42" Padding="8" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="تحديث" Command="{Binding RefreshCommand}" Style="{StaticResource ActionButtonStyle}"/>
                <Button Content="إغلاق" Command="{Binding CloseCommand}" Style="{StaticResource ActionButtonStyle}" CommandParameter="{RelativeSource AncestorType=Window}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
