<Window x:Class="FinalLabSystem.Views.Settings.TestDataManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="بيانات التحاليل"
        Height="860"
        Width="1320"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="102"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Background" Value="#A8E000"/>
            <Setter Property="Foreground" Value="#001A20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,4"/>
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#123A42"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Margin" Value="0,10,0,6"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="6,2"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F7FA" Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="40*"/>
            <ColumnDefinition Width="60*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Background="White" BorderBrush="#CFD8DC" BorderThickness="1" Padding="8" Margin="0,0,6,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,8">
                    <ComboBox DockPanel.Dock="Right"
                              Width="110"
                              ItemsSource="{Binding TestList.SearchModes}"
                              SelectedItem="{Binding TestList.SearchMode}"/>
                    <TextBox Text="{Binding TestList.SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="بحث"/>
                </DockPanel>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding TestList.FilteredTests}"
                          SelectedItem="{Binding TestList.SelectedTest}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Arrange#" Binding="{Binding SortOrder}" Width="60"/>
                        <DataGridTextColumn Header="Group" Binding="{Binding GroupNameAr}" Width="140"/>
                        <DataGridTextColumn Header="Code" Binding="{Binding TypeCode}" Width="80"/>
                        <DataGridTextColumn Header="Test Name" Binding="{Binding DisplayName}" Width="*"/>
                        <DataGridTextColumn Header="Patient Price" Binding="{Binding PatientPrice, StringFormat=N2}" Width="90"/>
                        <DataGridTextColumn Header="Lab-to-Lab" Binding="{Binding LabToLabPrice, StringFormat=N2}" Width="90"/>
                        <DataGridTextColumn Header="Tubes" Binding="{Binding TubeCount}" Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="0" Grid.Column="1" Background="White" BorderBrush="#CFD8DC" BorderThickness="1" Padding="10" Margin="6,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Identity" Style="{StaticResource SectionHeaderStyle}"/>
                    <UniformGrid Columns="3">
                        <StackPanel>
                            <TextBlock Text="Code"/>
                            <TextBox Text="{Binding TestDetail.TypeCode, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Test Name"/>
                            <TextBox Text="{Binding TestDetail.TypeNameEn, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Arabic Name"/>
                            <TextBox Text="{Binding TestDetail.TypeNameAr, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="History Name"/>
                            <TextBox Text="{Binding TestDetail.HistoryName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </UniformGrid>
                    <Separator/>

                    <TextBlock Text="Report Names" Style="{StaticResource SectionHeaderStyle}"/>
                    <UniformGrid Columns="2">
                        <StackPanel>
                            <TextBlock Text="Line 1"/>
                            <TextBox Text="{Binding TestDetail.ReportNameLine1, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Line 2"/>
                            <TextBox Text="{Binding TestDetail.ReportNameLine2, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </UniformGrid>
                    <Separator/>

                    <TextBlock Text="Bill Names" Style="{StaticResource SectionHeaderStyle}"/>
                    <UniformGrid Columns="2">
                        <StackPanel>
                            <TextBlock Text="Line 1"/>
                            <TextBox Text="{Binding TestDetail.BillNameLine1, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Line 2"/>
                            <TextBox Text="{Binding TestDetail.BillNameLine2, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </UniformGrid>
                    <Separator/>

                    <TextBlock Text="Classification" Style="{StaticResource SectionHeaderStyle}"/>
                    <UniformGrid Columns="3">
                        <StackPanel>
                            <TextBlock Text="Group"/>
                            <ComboBox ItemsSource="{Binding TestDetail.Groups}"
                                      DisplayMemberPath="GroupNameAr"
                                      SelectedValuePath="GroupId"
                                      SelectedValue="{Binding TestDetail.GroupId, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Arrange#"/>
                            <TextBox Text="{Binding TestDetail.SortOrder, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Test Time Hours"/>
                            <TextBox Text="{Binding TestDetail.TurnaroundHours, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </UniformGrid>
                    <Separator/>

                    <TextBlock Text="Workflow Flags" Style="{StaticResource SectionHeaderStyle}"/>
                    <WrapPanel>
                        <CheckBox Content="Is Routine Test" IsChecked="{Binding TestDetail.IsRoutineTest}"/>
                        <CheckBox Content="See Report" IsChecked="{Binding TestDetail.SeeReport}"/>
                        <CheckBox Content="Print With Other" IsChecked="{Binding TestDetail.PrintWithOther}"/>
                        <CheckBox Content="Add With Group" IsChecked="{Binding TestDetail.AddWithGroup}"/>
                        <CheckBox Content="Is Main Test" IsChecked="{Binding TestDetail.IsMainTest}"/>
                    </WrapPanel>
                    <Separator/>

                    <TextBlock Text="Notes" Style="{StaticResource SectionHeaderStyle}"/>
                    <TextBlock Text="Collection Notes"/>
                    <TextBox Text="{Binding TestDetail.CollectionNotes, UpdateSourceTrigger=PropertyChanged}" Height="58" AcceptsReturn="True" TextWrapping="Wrap"/>
                    <TextBlock Text="Notes"/>
                    <TextBox Text="{Binding TestDetail.Notes, UpdateSourceTrigger=PropertyChanged}" Height="58" AcceptsReturn="True" TextWrapping="Wrap"/>
                    <Separator/>

                    <TextBlock Text="Pricing" Style="{StaticResource SectionHeaderStyle}"/>
                    <UniformGrid Columns="2">
                        <StackPanel>
                            <TextBlock Text="Patient Price"/>
                            <TextBox Text="{Binding TestDetail.PatientPrice, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Lab-to-Lab Price"/>
                            <TextBox Text="{Binding TestDetail.LabToLabPrice, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </UniformGrid>
                    <Separator/>

                    <TextBlock Text="Zone C - Sample Tubes" Style="{StaticResource SectionHeaderStyle}"/>
                    <DataGrid ItemsSource="{Binding TestDetail.Tubes}"
                              SelectedItem="{Binding TestDetail.SelectedTube}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              Height="155">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Sort" Binding="{Binding SortOrder, UpdateSourceTrigger=PropertyChanged}" Width="55"/>
                            <DataGridTextColumn Header="Tube Type" Binding="{Binding TubeType, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                            <DataGridTextColumn Header="Tube Color" Binding="{Binding TubeColor, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                            <DataGridTextColumn Header="Sample Type" Binding="{Binding SampleType, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="55"/>
                            <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                            <DataGridTextColumn Header="Notes" Binding="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="Add" Command="{Binding TestDetail.AddTubeCommand}" Style="{StaticResource ActionButtonStyle}"/>
                        <Button Content="Edit" Command="{Binding TestDetail.EditTubeCommand}" Style="{StaticResource ActionButtonStyle}"/>
                        <Button Content="Delete" Command="{Binding TestDetail.DeleteTubeCommand}" Style="{StaticResource ActionButtonStyle}"/>
                    </StackPanel>
                    <Separator/>

                    <TextBlock Text="Zone D - Outside Lab" Style="{StaticResource SectionHeaderStyle}"/>
                    <CheckBox Content="Is Send Outside" IsChecked="{Binding TestDetail.IsSendOutside}"/>
                    <UniformGrid Columns="2">
                        <StackPanel>
                            <TextBlock Text="Outside Lab Name"/>
                            <TextBox Text="{Binding TestDetail.OutsideLabName, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding TestDetail.IsOutsideFieldsEnabled}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Outside Cost Price"/>
                            <TextBox Text="{Binding TestDetail.OutsideCostPrice, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding TestDetail.IsOutsideFieldsEnabled}"/>
                        </StackPanel>
                    </UniformGrid>
                    <Separator/>

                    <TextBlock Text="Zone E - Patient Question" Style="{StaticResource SectionHeaderStyle}"/>
                    <TextBox Text="{Binding TestDetail.PatientQuestion, UpdateSourceTrigger=PropertyChanged}" Height="70" AcceptsReturn="True" TextWrapping="Wrap"/>
                    <Button Content="القيم الطبيعية" Command="{Binding TestDetail.OpenNormalRangesCommand}" Style="{StaticResource ActionButtonStyle}" HorizontalAlignment="Left" Margin="4,12,4,4"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#123A42" BorderBrush="#0A252C" BorderThickness="3" Padding="5" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="جديد" Command="{Binding NewCommand}" Style="{StaticResource ActionButtonStyle}"/>
                <Button Content="حفظ" Command="{Binding SaveCommand}" Style="{StaticResource ActionButtonStyle}" Background="#8BC34A"/>
                <Button Content="حذف" Command="{Binding DeleteCommand}" Style="{StaticResource ActionButtonStyle}"/>
                <Button Content="تحديث" Command="{Binding TestList.RefreshCommand}" Style="{StaticResource ActionButtonStyle}"/>
                <Button Content="إغلاق" Command="{Binding CloseCommand}" Style="{StaticResource ActionButtonStyle}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
