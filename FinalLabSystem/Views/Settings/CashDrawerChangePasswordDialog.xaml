<Window x:Class="FinalLabSystem.Views.Settings.CashDrawerChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تغيير كلمة مرور درج النقدية"
        Height="320" Width="400"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="تغيير كلمة مرور درج النقدية"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,16"
                   HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="1" Text="كلمة المرور الحالية:" Margin="0,0,0,4"/>
        <PasswordBox Grid.Row="2" x:Name="CurrentPasswordBox"
                     Height="30" Margin="0,0,0,12"
                     KeyDown="Password_KeyDown"/>

        <TextBlock Grid.Row="3" Text="كلمة المرور الجديدة:" Margin="0,0,0,4"/>
        <PasswordBox Grid.Row="4" x:Name="NewPasswordBox"
                     Height="30" Margin="0,0,0,12"
                     KeyDown="Password_KeyDown"/>

        <TextBlock Grid.Row="5" Text="تأكيد كلمة المرور الجديدة:" Margin="0,0,0,4"/>
        <PasswordBox Grid.Row="6" x:Name="ConfirmPasswordBox"
                     Height="30" Margin="0,0,0,4"
                     KeyDown="Password_KeyDown"/>

        <TextBlock x:Name="ErrorText" Foreground="Red" FontSize="12"
                   Visibility="Collapsed" Margin="0,4,0,0"
                   HorizontalAlignment="Center"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,12,0,0">
            <Button Content="حفظ" Click="OK_Click"
                    Width="80" Height="30" Margin="8,0"
                    Background="#1976D2" Foreground="White" FontWeight="Bold"/>
            <Button Content="إلغاء" Click="Cancel_Click"
                    Width="80" Height="30" Margin="8,0"
                    Background="#E53935" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
