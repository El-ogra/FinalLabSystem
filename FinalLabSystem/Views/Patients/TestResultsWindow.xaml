<Window x:Class="FinalLabSystem.Views.Patients.TestResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إدخال نتائج التحاليل"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        Background="#0D2137"
        Loaded="Window_Loaded">
    <Window.Resources>
        <!-- Status color mapping -->
        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SingleComponentStatus}" Value="HIGH">
                    <Setter Property="Foreground" Value="#F44336"/>
                    <Setter Property="Text" Value="High"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SingleComponentStatus}" Value="LOW">
                    <Setter Property="Foreground" Value="#2196F3"/>
                    <Setter Property="Text" Value="Low"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SingleComponentStatus}" Value="HIGH_CRITICAL">
                    <Setter Property="Foreground" Value="#FF0000"/>
                    <Setter Property="Text" Value="Critical High"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SingleComponentStatus}" Value="LOW_CRITICAL">
                    <Setter Property="Foreground" Value="#0000FF"/>
                    <Setter Property="Text" Value="Critical Low"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SingleComponentStatus}" Value="NORMAL">
                    <Setter Property="Foreground" Value="#4CAF50"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Button style for row action buttons -->
        <Style x:Key="RowActionButton" TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Button style for bottom bar -->
        <Style x:Key="BottomBarButton" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Checkbox style for DataGrid -->
        <Style x:Key="DataGridCheckBox" TargetType="CheckBox">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- شريط التنقل السفلي -->
        <Border DockPanel.Dock="Bottom" Background="#0A252C" Padding="6">
            <WrapPanel Orientation="Horizontal">
                <Button Content="بيانات المرضى" Command="{Binding OpenPatientDataCommand}"
                        Style="{StaticResource BottomBarButton}"
                        Background="#2A5A62"/>

                <Separator Background="#3A5068" Width="1" Margin="6,2" Height="20"/>

                <Button Content="طباعة ظرف" Command="{Binding PrintEnvelopeCommand}"
                        Style="{StaticResource BottomBarButton}"
                        Background="#FFC107" Foreground="#0A252C"/>
                <Button Content="تقرير فارغ" Command="{Binding PrintBlankReportCommand}"
                        Style="{StaticResource BottomBarButton}"
                        Background="#FFC107" Foreground="#0A252C"/>
                <Button Content="التاريخ المرضي" Command="{Binding PrintMedicalHistoryCommand}"
                        Style="{StaticResource BottomBarButton}"
                        Background="#FFC107" Foreground="#0A252C"/>

                <Separator Background="#3A5068" Width="1" Margin="6,2" Height="20"/>

                <Button Content="طباعة" Command="{Binding PrintCompositeReportCommand}"
                        Style="{StaticResource BottomBarButton}"
                        Background="#FFC107" Foreground="#0A252C" IsEnabled="{Binding CanPrint}"/>
                <Button Content="تقرير مجمع" Command="{Binding PrintCompositeReportCommand}"
                        Style="{StaticResource BottomBarButton}"
                        Background="#FFC107" Foreground="#0A252C"/>

                <Separator Background="#3A5068" Width="1" Margin="6,2" Height="20"/>

                <Button Content="معاينة" Command="{Binding PreviewReportCommand}"
                        Style="{StaticResource BottomBarButton}"
                        Background="#42A5F5"/>
                <Button Content="إرسال SMS" Command="{Binding SendSmsCommand}"
                        Style="{StaticResource BottomBarButton}"
                        Background="#66BB6A"/>

                <Separator Background="#3A5068" Width="1" Margin="6,2" Height="20"/>

                <Button Content="العودة للرئيسية" Command="{Binding ReturnToMainCommand}"
                        Style="{StaticResource BottomBarButton}"
                        Background="#F44336"/>

                <!-- Print Queue -->
                <Button Style="{StaticResource BottomBarButton}"
                        Background="#FF9800"
                        Foreground="White"
                        Content="إضافة للقائمة"
                        Command="{Binding AddToPrintQueueCommand}"
                        ToolTip="إضافة إلى قائمة الطباعة (Ctrl+Q)" />

                <Button Style="{StaticResource BottomBarButton}"
                        Background="#FF9800"
                        Foreground="White"
                        Content="قائمة الطباعة"
                        Command="{Binding OpenPrintQueueCommand}"
                        ToolTip="فتح قائمة الطباعة (Ctrl+Shift+Q)" />
            </WrapPanel>
        </Border>

        <!-- المحتوى الرئيسي -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="2.5*"/>
            </Grid.ColumnDefinitions>

            <!-- العمود الأيمن: قائمة المرضى -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header: العنوان + العداد + البحث -->
                <Border Grid.Row="0" Background="#1A4A52" Padding="6">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                            <TextBlock Text="عدد المرضى اليوم" FontWeight="Bold" FontSize="13"
                                       Foreground="#FFFFFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding PatientCount}" Foreground="#4FC3F7" FontSize="18" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBox Width="200" Height="26" Margin="0,0,0,4"
                                 Background="#FFFFFF" Foreground="#333333"
                                 BorderBrush="#3A5068" BorderThickness="1"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center" Padding="4,2" FontSize="12"
                                 FlowDirection="RightToLeft"/>
                    </StackPanel>
                </Border>

                <ListView Grid.Row="1" ItemsSource="{Binding PatientsView}"
                          SelectedItem="{Binding SelectedPatient}"
                          Background="#0E2830" Foreground="#FFFFFF"
                          BorderBrush="#3A5068" BorderThickness="1"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1976D2"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsVip}" Value="True">
                                    <Setter Property="Background" Value="#FFF8E1"/>
                                    <Setter Property="BorderBrush" Value="#FFD700"/>
                                    <Setter Property="BorderThickness" Value="2,0,2,0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding StatusIcon}"
                                           Foreground="{Binding StatusColor}"
                                           FontFamily="Segoe UI Emoji"
                                           FontSize="18" FontWeight="Bold"
                                           Width="28" TextAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <StackPanel Margin="4,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding FullNameAr}"
                                                   FontWeight="SemiBold" FontSize="13"/>
                                        <Border Background="#FFD700" CornerRadius="3"
                                                Padding="4,1" Margin="6,0,0,0"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsVip}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="VIP" Foreground="#333333"
                                                       FontWeight="Bold" FontSize="9"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding PatientCode}"
                                                   Foreground="#88AAAAAA" FontSize="11"/>
                                        <TextBlock Text=" | " Foreground="#88AAAAAA" FontSize="11"/>
                                        <TextBlock Text="{Binding ReferralName}"
                                                   Foreground="#88AAAAAA" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- أزرار الفلاتر أسفل القائمة -->
                <Border Grid.Row="2" Background="#0A252C" Padding="6,4" Margin="0">
                    <StackPanel HorizontalAlignment="Center">
                        <Button Content="&#x21BB; Refresh"
                                Command="{Binding RefreshCommand}"
                                MinWidth="90" Height="30" Margin="0,0,0,4"
                                Background="#4CAF50" Foreground="White" FontSize="13"
                                FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                                HorizontalAlignment="Center"/>
                        <UniformGrid Rows="2" Columns="3" HorizontalAlignment="Center">
                            <Button Content="Individual"
                                    Command="{Binding SetPatientTypeCommand}"
                                    CommandParameter="Individual"
                                    Width="70" Height="24" Margin="2"
                                    Background="{Binding SelectedPatientType, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Individual}"
                                    Foreground="#FFFFFF" FontSize="11" BorderThickness="1"
                                    BorderBrush="#3A5068" Cursor="Hand"/>
                            <Button Content="LabToLak"
                                    Command="{Binding SetPatientTypeCommand}"
                                    CommandParameter="LabToLak"
                                    Width="65" Height="24" Margin="2"
                                    Background="{Binding SelectedPatientType, Converter={StaticResource StringEqualsConverter}, ConverterParameter=LabToLak}"
                                    Foreground="#FFFFFF" FontSize="11" BorderThickness="1"
                                    BorderBrush="#3A5068" Cursor="Hand"/>
                            <Button Content="Contracts"
                                    Command="{Binding SetPatientTypeCommand}"
                                    CommandParameter="Contracts"
                                    Width="68" Height="24" Margin="2"
                                    Background="{Binding SelectedPatientType, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Contracts}"
                                    Foreground="#FFFFFF" FontSize="11" BorderThickness="1"
                                    BorderBrush="#3A5068" Cursor="Hand"/>
                            <Button Content="VIP"
                                    Command="{Binding SetPatientTypeCommand}"
                                    CommandParameter="VIP"
                                    Width="40" Height="24" Margin="2"
                                    Background="{Binding SelectedPatientType, Converter={StaticResource StringEqualsConverter}, ConverterParameter=VIP}"
                                    Foreground="#FFFFFF" FontSize="11" BorderThickness="1"
                                    BorderBrush="#3A5068" Cursor="Hand"/>
                            <Button Content="Free"
                                    Command="{Binding SetPatientTypeCommand}"
                                    CommandParameter="Free"
                                    Width="40" Height="24" Margin="2"
                                    Background="{Binding SelectedPatientType, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Free}"
                                    Foreground="#FFFFFF" FontSize="11" BorderThickness="1"
                                    BorderBrush="#3A5068" Cursor="Hand"/>
                            <Button Content="الكل"
                                    Command="{Binding SetPatientTypeCommand}"
                                    CommandParameter="All"
                                    Width="50" Height="24" Margin="2"
                                    Background="{Binding SelectedPatientType, Converter={StaticResource StringEqualsConverter}, ConverterParameter=All}"
                                    Foreground="#FFFFFF" FontSize="11" BorderThickness="1"
                                    BorderBrush="#3A5068" Cursor="Hand"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" Width="4" Background="#3A5068"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

            <!-- العمود الأيسر: التفاصيل -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- بيانات المريض (الجزء العلوي) -->
                <Border Grid.Row="0" Background="#FFD700" Padding="8"
                        BorderBrush="#3A5068" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- صورة المريض (تمتد صفّين) -->
                        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                Background="#2A4A5A" CornerRadius="4"
                                Width="52" Height="52" Margin="0,0,10,0"
                                VerticalAlignment="Center" ClipToBounds="True">
                            <Grid>
                                <Image Stretch="UniformToFill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Source" Value="{Binding CurrentPatientInfo.PhotoPath}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentPatientInfo.PhotoPath}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding CurrentPatientInfo.PhotoPath}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="&#x1F464;" FontFamily="Segoe UI Emoji" FontSize="24"
                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentPatientInfo.PhotoPath}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding CurrentPatientInfo.PhotoPath}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- الصف العلوي: الكود | الاسم | الجنس -->
                        <Grid Grid.Row="0" Grid.Column="1" FlowDirection="RightToLeft">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- الجنس -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="8,0">
                                <Border Background="#1976D2" CornerRadius="3" Padding="4,2"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="الجنس" Foreground="#FFFFFF" FontWeight="Bold" FontSize="10"/>
                                </Border>
                                <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1"
                                        CornerRadius="2" Padding="4,2" MinWidth="40"
                                        VerticalAlignment="Center" Margin="4,0,0,0">
                                    <TextBlock Text="{Binding CurrentPatientInfo.Sex, FallbackValue='--'}"
                                               Foreground="#333333" FontWeight="Bold" FontSize="12"/>
                                </Border>
                            </StackPanel>

                            <!-- الاسم -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0">
                                <Border Background="#1976D2" CornerRadius="3" Padding="4,2"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="الاسم" Foreground="#FFFFFF" FontWeight="Bold" FontSize="10"/>
                                </Border>
                                <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1"
                                        CornerRadius="2" Padding="4,2" MinWidth="120"
                                        VerticalAlignment="Center" Margin="4,0,0,0">
                                    <TextBlock Text="{Binding CurrentPatientInfo.FullNameAr, FallbackValue='--'}"
                                               Foreground="#333333" FontWeight="Bold" FontSize="12"
                                               TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                </Border>
                            </StackPanel>

                            <!-- الكود -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0">
                                <Border Background="#1976D2" CornerRadius="3" Padding="4,2"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="الكود" Foreground="#FFFFFF" FontWeight="Bold" FontSize="10"/>
                                </Border>
                                <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1"
                                        CornerRadius="2" Padding="4,2" MinWidth="100"
                                        VerticalAlignment="Center" Margin="4,0,0,0" Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding CopyCodeCommand}"/>
                                    </Border.InputBindings>
                                    <TextBlock Text="{Binding CurrentPatientInfo.PatientCode, FallbackValue='--'}"
                                               Foreground="#333333" FontWeight="Bold" FontSize="12"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- الصف السفلي: الجهة | Lab ID | العمر -->
                        <Grid Grid.Row="1" Grid.Column="1" FlowDirection="RightToLeft" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- العمر -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="8,0">
                                <Border Background="#1976D2" CornerRadius="3" Padding="4,2"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="العمر" Foreground="#FFFFFF" FontWeight="Bold" FontSize="10"/>
                                </Border>
                                <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1"
                                        CornerRadius="2" Padding="4,2" MinWidth="60"
                                        VerticalAlignment="Center" Margin="4,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding CurrentPatientInfo.ApproxAge, FallbackValue='--'}"
                                                   Foreground="#333333" FontWeight="Bold" FontSize="12"/>
                                        <TextBlock Text="{Binding CurrentPatientInfo.ApproxAgeUnit, FallbackValue='Years'}"
                                                   Foreground="#666666" FontSize="10" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Lab ID -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0">
                                <Border Background="#4CAF50" CornerRadius="3" Padding="4,2"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="Lab ID" Foreground="#FFFFFF" FontWeight="Bold" FontSize="10"/>
                                </Border>
                                <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1"
                                        CornerRadius="2" Padding="4,2" MinWidth="50"
                                        VerticalAlignment="Center" Margin="4,0,0,0">
                                    <TextBlock Text="{Binding CurrentPatientInfo.VisitCode, FallbackValue='--'}"
                                               Foreground="#333333" FontWeight="Bold" FontSize="12"/>
                                </Border>
                                <Border Background="#4CAF50" CornerRadius="4" Padding="10,4"
                                        VerticalAlignment="Center" Margin="6,0,0,0">
                                    <TextBlock Text="{Binding CurrentPatientInfo.VisitCount, FallbackValue='0'}"
                                               Foreground="#FFFFFF" FontWeight="Bold" FontSize="14"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <!-- الجهة -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0">
                                <Border Background="#1976D2" CornerRadius="3" Padding="4,2"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="الجهة" Foreground="#FFFFFF" FontWeight="Bold" FontSize="10"/>
                                </Border>
                                <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1"
                                        CornerRadius="2" Padding="4,2" MinWidth="100"
                                        VerticalAlignment="Center" Margin="4,0,0,0">
                                    <TextBlock Text="{Binding CurrentPatientInfo.ReferralName, FallbackValue='--'}"
                                               Foreground="#333333" FontWeight="Bold" FontSize="12"
                                               MaxWidth="180" TextTrimming="CharacterEllipsis"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- جدول التحاليل -->
                <DataGrid Grid.Row="1" x:Name="TestsDataGrid"
                          ItemsSource="{Binding PatientTests}"
                          SelectedItem="{Binding SelectedTest}"
                          AutoGenerateColumns="False" IsReadOnly="False"
                          CanUserAddRows="False"
                          FlowDirection="LeftToRight"
                          RowDetailsVisibilityMode="VisibleWhenSelected"
                          Background="#FFFFFF" Foreground="#333333"
                          RowBackground="#FFFFFF" AlternatingRowBackground="#F5F5F5"
                          BorderBrush="#E0E0E0" BorderThickness="1"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#E0E0E0"
                          Margin="4">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick"
                                      Command="{Binding HandleRowActivateCommand}"/>
                        <KeyBinding Key="Enter"
                                    Command="{Binding HandleRowActivateCommand}"/>
                    </DataGrid.InputBindings>
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#E0E0E0"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderBrush" Value="#CCCCCC"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="Padding" Value="6,4"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="4,2"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1976D2"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1976D2"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsMultiComponent}" Value="True">
                                    <Setter Property="Background" Value="#FFF3E0"/>
                                    <Setter Property="Foreground" Value="#333333"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <!-- 1. التحليل + أزرار P/T في الرأس -->
                        <DataGridTemplateColumn Header="Test Abbreviation" Width="*">
                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                    Margin="4,0,0,0">
                                            <Button Content="P"
                                                    Command="{Binding DataContext.ShowAuditPCommand,
                                                        RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    Width="22" Height="18" Margin="2,0,0,0"
                                                    Background="#8B0000" Foreground="White"
                                                    FontSize="9" FontWeight="Bold" BorderThickness="0"
                                                    ToolTip="سجل تدقيق الزيارة"
                                                    Cursor="Hand"/>
                                            <Button Content="T"
                                                    Command="{Binding DataContext.ShowAuditTCommand,
                                                        RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    Width="22" Height="18" Margin="2,0,0,0"
                                                    Background="#8B0000" Foreground="White"
                                                    FontSize="9" FontWeight="Bold" BorderThickness="0"
                                                    ToolTip="سجل تدقيق التحليل"
                                                    Cursor="Hand"/>
                                        </StackPanel>
                                        <TextBlock Text="التحليل" VerticalAlignment="Center"
                                                   FontWeight="SemiBold"/>
                                    </DockPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TestTypeName}"
                                               Foreground="{Binding SingleComponentStatus,
                                                   Converter={StaticResource AbnormalStatusToBrushConverter}}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding TestTypeName}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- 3. النتيجة (عرض + إدخال inline لأحادي المكوّن فقط) -->
                        <DataGridTemplateColumn Header="Result" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                     <TextBox Text="{Binding SingleComponentResultValue,
                                                 Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              BorderThickness="1" Background="#FFFFFF"
                                              Foreground="#0A252C" BorderBrush="#3A5068"
                                              FontWeight="Bold"
                                              Padding="4,2" VerticalContentAlignment="Center"
                                              ToolTip="{Binding SingleComponentResultValue}"
                                              KeyDown="ResultTextBox_KeyDown">
                                         <TextBox.Style>
                                             <Style TargetType="TextBox">
                                                 <Style.Triggers>
                                                     <DataTrigger Binding="{Binding IsMultiComponent}" Value="True">
                                                         <Setter Property="IsReadOnly" Value="True"/>
                                                         <Setter Property="Background" Value="#FFF3E0"/>
                                                         <Setter Property="Text" Value="See Report"/>
                                                         <Setter Property="Foreground" Value="#E65100"/>
                                                         <Setter Property="FontStyle" Value="Italic"/>
                                                     </DataTrigger>
                                                 </Style.Triggers>
                                             </Style>
                                         </TextBox.Style>
                                     </TextBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- 4. الحالة -->
                        <DataGridTemplateColumn Header="Status" Width="80" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SingleComponentStatus}"
                                               Style="{StaticResource StatusTextStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- 5. مكتمل (Finish) -->
                        <DataGridTemplateColumn Header="Finish" Width="55" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsManuallyOverridden}"
                                              Style="{StaticResource DataGridCheckBox}"
                                              IsEnabled="False"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- 6. مُراجَع (Verify) -->
                        <DataGridTemplateColumn Header="Verify" Width="55" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsAllReviewed, Mode=OneWay}"
                                              Style="{StaticResource DataGridCheckBox}"
                                              IsEnabled="False"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- 7. مطبوع (Print) -->
                        <DataGridTemplateColumn Header="Print" Width="55" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsPrinted}"
                                              Style="{StaticResource DataGridCheckBox}"
                                              IsEnabled="False"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- 8. مُصدَّر (Export) -->
                        <DataGridTemplateColumn Header="Export" Width="55" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsExported, Mode=OneWay}"
                                              Style="{StaticResource DataGridCheckBox}"
                                              IsEnabled="True"
                                              Command="{Binding DataContext.ToggleExportCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>

                    <!-- RowDetailsTemplate: المكوّنات (للتحاليل متعددة المكوّنات فقط) -->
                    <DataGrid.RowDetailsTemplate>
                        <DataTemplate>
                            <Border Background="#F0F0F0" Padding="8" Margin="4,4,4,8"
                                    BorderBrush="#E0E0E0" BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TotalComponents}" Value="1">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="المكوّنات:"
                                               Foreground="#666666" FontWeight="SemiBold"
                                               Margin="0,0,0,4"/>
                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding ComponentResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#F9F9F9" CornerRadius="4"
                                                        Padding="8,6" Margin="2" BorderBrush="#E0E0E0" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="150"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="120"/>
                                                            <ColumnDefinition Width="60"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding ComponentName}"
                                                                   FontWeight="SemiBold" Foreground="#333333"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding ResultValue}"
                                                                   FontWeight="Bold" Foreground="#1976D2"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ResultStatus}"
                                                                   FontWeight="Bold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ResultStatus}" Value="HIGH">
                                                                            <Setter Property="Foreground" Value="#F44336"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding ResultStatus}" Value="LOW">
                                                                            <Setter Property="Foreground" Value="#2196F3"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding ResultStatus}" Value="HIGH_CRITICAL">
                                                                            <Setter Property="Foreground" Value="#FF0000"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding ResultStatus}" Value="LOW_CRITICAL">
                                                                            <Setter Property="Foreground" Value="#0000FF"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding ResultStatus}" Value="NORMAL">
                                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Grid.Column="3" Text="{Binding SnapNormalText}"
                                                                   Foreground="#888888"/>
                                                        <TextBlock Grid.Column="4" Text="{Binding SnapUnit}"
                                                                   Foreground="#888888"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </DataGrid.RowDetailsTemplate>
                </DataGrid>

                <!-- أزرار الإجراءات أسفل الجدول -->
                <Border Grid.Row="2" Background="#0A252C" Padding="6,4" Margin="4,0">
                    <Grid FlowDirection="LeftToRight">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- طبعت -->
                        <Button Grid.Column="0" Content="طبعت"
                                Command="{Binding TogglePrintCommand}"
                                Style="{StaticResource RowActionButton}"
                                Background="#FFC107" Foreground="#333333"/>

                        <!-- مراجعة -->
                        <Button Grid.Column="1" Content="مراجعة"
                                Command="{Binding MarkReviewedCommand}"
                                Style="{StaticResource RowActionButton}"
                                Background="#FFC107" Foreground="#333333"/>

                        <!-- تمت -->
                        <Button Grid.Column="2" Content="تمت"
                                Command="{Binding ManualOverrideCommand}"
                                Style="{StaticResource RowActionButton}"
                                Background="#FFC107" Foreground="#333333"/>

                        <!-- تراجع -->
                        <Button Grid.Column="3" Content="تراجع"
                                Command="{Binding UndoManualOverrideCommand}"
                                Style="{StaticResource RowActionButton}"
                                Background="#607D8B"/>

                        <!-- حفظ -->
                        <Button Grid.Column="4" Content="حفظ"
                                Command="{Binding SaveInlineResultCommand}"
                                Style="{StaticResource RowActionButton}"
                                Background="#4CAF50"/>

                        <!-- مربع نص الملاحظات السريعة -->
                        <TextBox Grid.Column="5"
                                 Text="{Binding QuickNoteText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#1A4A52" Foreground="#FFFFFF"
                                 BorderBrush="#3A5068" BorderThickness="1"
                                 Margin="6,0" VerticalContentAlignment="Center"
                                 Padding="4,2" FontSize="11">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter"
                                            Command="{Binding SaveQuickNoteCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>

                        <!-- زر ملاحظات -->
                        <Button Grid.Column="6" Content="ملاحظات"
                                Command="{Binding AddEditNotesCommand}"
                                Style="{StaticResource RowActionButton}"
                                Background="#5C6BC0"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Keyboard shortcuts status bar -->
        <Border DockPanel.Dock="Bottom" Background="#1A4A52" Padding="4,2">
            <TextBlock Foreground="#88AAAAAA" FontSize="10" FlowDirection="LeftToRight">
                <Run Text="F2:Patient Data"/>
                <Run Text=" | "/>
                <Run Text="F3:Search"/>
                <Run Text=" | "/>
                <Run Text="F4:Results"/>
                <Run Text=" | "/>
                <Run Text="F5:Refresh"/>
                <Run Text=" | "/>
                <Run Text="F6:Delivery"/>
                <Run Text=" | "/>
                <Run Text="F7:External"/>
                <Run Text=" | "/>
                <Run Text="F8:Edit Patient"/>
                <Run Text=" | "/>
                <Run Text="F12:Print Receipt"/>
                <Run Text=" | "/>
                <Run Text="Ctrl+R:Review"/>
                <Run Text=" | "/>
                <Run Text="Ctrl+F:Finish"/>
                <Run Text=" | "/>
                <Run Text="Ctrl+P:Print"/>
            </TextBlock>
        </Border>

        <!-- Busy overlay -->
        <Border Grid.Row="0" Grid.ColumnSpan="3"
                Background="#80000000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisConverter}}"
                IsHitTestVisible="True">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="جاري التحميل..." FontSize="18" Foreground="#FFFFFF"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </DockPanel>

    <Window.InputBindings>
        <KeyBinding Key="F2" Command="{Binding OpenPatientDataCommand}"/>
        <KeyBinding Key="F3" Command="{Binding OpenSearchCommand}"/>
        <KeyBinding Key="F4" Command="{Binding NavigateToResultEntryCommand}"/>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
        <KeyBinding Key="F6" Command="{Binding OpenDeliveryCommand}"/>
        <KeyBinding Key="F7" Command="{Binding NavigateToExternalSamplesCommand}"/>
        <KeyBinding Key="F8" Command="{Binding EditSelectedPatientCommand}"/>
        <KeyBinding Key="F12" Command="{Binding PrintReceiptCommand}"/>
        <KeyBinding Key="R" Modifiers="Ctrl" Command="{Binding ToggleReviewStatusCommand}"/>
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{Binding ToggleFinishStatusCommand}"/>
        <KeyBinding Key="P" Modifiers="Ctrl" Command="{Binding TogglePrintStatusCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding ReturnToMainCommand}"/>
        <KeyBinding Key="Q" Modifiers="Ctrl" Command="{Binding AddToPrintQueueCommand}" />
        <KeyBinding Key="Q" Modifiers="Ctrl+Shift" Command="{Binding OpenPrintQueueCommand}" />
    </Window.InputBindings>
</Window>
