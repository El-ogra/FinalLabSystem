<Window x:Class="FinalLabSystem.Views.Patients.TestResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إدخال نتائج التحاليل"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        Background="#123A42"
        Loaded="Window_Loaded">
    <Window.Resources>
        <!-- Status color mapping -->
        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SingleComponentStatus}" Value="HIGH">
                    <Setter Property="Foreground" Value="#F44336"/>
                    <Setter Property="Text" Value="High"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SingleComponentStatus}" Value="LOW">
                    <Setter Property="Foreground" Value="#2196F3"/>
                    <Setter Property="Text" Value="Low"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SingleComponentStatus}" Value="HIGH_CRITICAL">
                    <Setter Property="Foreground" Value="#FF0000"/>
                    <Setter Property="Text" Value="Critical High"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SingleComponentStatus}" Value="LOW_CRITICAL">
                    <Setter Property="Foreground" Value="#0000FF"/>
                    <Setter Property="Text" Value="Critical Low"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SingleComponentStatus}" Value="NORMAL">
                    <Setter Property="Foreground" Value="#4CAF50"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Button style for row action buttons -->
        <Style x:Key="RowActionButton" TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Button style for bottom bar -->
        <Style x:Key="BottomBarButton" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Checkbox style for DataGrid -->
        <Style x:Key="DataGridCheckBox" TargetType="CheckBox">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- شريط الفلاتر (Top) -->
        <Border DockPanel.Dock="Top" Background="#0A252C" Padding="6">
            <WrapPanel Orientation="Horizontal">
                <RadioButton Content="الكل" GroupName="Filter" IsChecked="True"
                             Foreground="#FFFFFF" Margin="8,0"
                             Command="{Binding ClearFilterCommand}"/>
                <RadioButton Content="غير مكتوب" GroupName="Filter"
                             Foreground="#FF8C00" Margin="8,0"
                             Command="{Binding ApplyFilterCommand}"
                             CommandParameter="HasUnwrittenResults"/>
                <RadioButton Content="غير مراجَع" GroupName="Filter"
                             Foreground="#FFD700" Margin="8,0"
                             Command="{Binding ApplyFilterCommand}"
                             CommandParameter="HasUnreviewedResults"/>
                <RadioButton Content="VIP" GroupName="Filter"
                             Foreground="#FF4444" Margin="8,0"
                             Command="{Binding ApplyFilterCommand}"
                             CommandParameter="VIP"/>
                <RadioButton Content="خارجي" GroupName="Filter"
                             Foreground="#4FC3F7" Margin="8,0"
                             Command="{Binding ApplyFilterCommand}"
                             CommandParameter="External"/>

                <Separator Background="#3A5068" Width="1" Margin="8,2" Height="20"/>

                <Button Content="◀" Command="{Binding NavigateDayCommand}" CommandParameter="-1"
                        Width="28" Height="24" Background="#3A5068" Foreground="#FFFFFF"
                        Margin="3,0" BorderThickness="0" FontSize="12"/>
                <TextBlock Text="{Binding SelectedDateDisplay}" Foreground="#FFFFFF"
                           VerticalAlignment="Center" Margin="4,0" FontWeight="SemiBold"/>
                <Button Content="▶" Command="{Binding NavigateDayCommand}" CommandParameter="1"
                        Width="28" Height="24" Background="#3A5068" Foreground="#FFFFFF"
                        Margin="3,0" BorderThickness="0" FontSize="12"/>

                <Separator Background="#3A5068" Width="1" Margin="8,2" Height="20"/>

                <TextBox Width="180" Height="24" Margin="4,0"
                         Background="#1A4A52" Foreground="#FFFFFF"
                         BorderBrush="#3A5068" BorderThickness="1"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center" Padding="4,2"/>
            </WrapPanel>
        </Border>

        <!-- شريط التنقل السفلي -->
        <Border DockPanel.Dock="Bottom" Background="#0A252C" Padding="6">
            <WrapPanel Orientation="Horizontal">
                <Button Content="بيانات المرضى" Command="{Binding OpenPatientDataCommand}"
                        Style="{StaticResource BottomBarButton}"
                        Background="#2A5A62"/>
                <Button Content="طباعة ظرف" Command="{Binding PrintEnvelopeCommand}"
                        Style="{StaticResource BottomBarButton}"
                        Background="#2A5A62"/>
                <Button Content="تقرير فارغ" Command="{Binding PrintBlankReportCommand}"
                        Style="{StaticResource BottomBarButton}"
                        Background="#2A5A62"/>
                <Button Content="التاريخ المرضي" Command="{Binding PrintMedicalHistoryCommand}"
                        Style="{StaticResource BottomBarButton}"
                        Background="#2A5A62"/>

                <Separator Background="#3A5068" Width="1" Margin="6,2" Height="20"/>

                <Button Content="طباعة" Command="{Binding PrintCompositeReportCommand}"
                        Style="{StaticResource BottomBarButton}"
                        Background="#2A5A62" IsEnabled="{Binding CanPrint}"/>
                <Button Content="تقرير مجمع" Command="{Binding PrintCompositeReportCommand}"
                        Style="{StaticResource BottomBarButton}"
                        Background="#2A5A62"/>

                <Separator Background="#3A5068" Width="1" Margin="6,2" Height="20"/>

                <Button Content="العودة للرئيسية" Command="{Binding ReturnToMainCommand}"
                        Height="30" Margin="4,0" Padding="10,0"
                        Background="#F44336" Foreground="White" BorderThickness="0"/>
            </WrapPanel>
        </Border>

        <!-- المحتوى الرئيسي -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- العمود الأيمن: قائمة المرضى -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#1A4A52" Padding="6">
                    <TextBlock Text="مرضى اليوم" FontWeight="Bold" FontSize="14"
                               Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                </Border>

                <ListView Grid.Row="1" ItemsSource="{Binding PatientsView}"
                          SelectedItem="{Binding SelectedPatient}"
                          Background="#0E2830" Foreground="#FFFFFF"
                          BorderBrush="#3A5068" BorderThickness="1"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1A6EA8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding StatusIcon}"
                                           Foreground="{Binding StatusColor}"
                                           FontSize="18" FontWeight="Bold"
                                           Width="28" TextAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <StackPanel Margin="4,0,0,0">
                                    <TextBlock Text="{Binding FullNameAr}"
                                               FontWeight="SemiBold" FontSize="13"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding PatientCode}"
                                                   Foreground="#88AAAAAA" FontSize="11"/>
                                        <TextBlock Text=" | " Foreground="#88AAAAAA" FontSize="11"/>
                                        <TextBlock Text="{Binding ReferralName}"
                                                   Foreground="#88AAAAAA" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" Width="4" Background="#3A5068"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

            <!-- العمود الأيسر: التفاصيل -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- بيانات المريض (الجزء العلوي) -->
                <Border Grid.Row="0" Background="#0E2830" Padding="8"
                        BorderBrush="#3A5068" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- الجنس -->
                        <Border Grid.Column="0" Background="#FF9800" CornerRadius="4"
                                Padding="10,4" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="الجنس:" Foreground="#FFFFFF" FontWeight="Bold"
                                           Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CurrentPatientInfo.Sex, FallbackValue='--'}"
                                           Foreground="#FFFFFF" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- المعلومات الأساسية -->
                        <Grid Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- الاسم -->
                            <StackPanel Grid.Column="0" Margin="8,0">
                                <TextBlock Text="الاسم:" Foreground="#88AAAAAA" FontSize="11"/>
                                <TextBlock Text="{Binding CurrentPatientInfo.FullNameAr, FallbackValue='--'}"
                                           Foreground="#FFFFFF" FontWeight="Bold" FontSize="13"/>
                            </StackPanel>

                            <!-- الكود -->
                            <StackPanel Grid.Column="1" Margin="8,0">
                                <TextBlock Text="الكود:" Foreground="#88AAAAAA" FontSize="11"/>
                                <TextBlock Text="{Binding CurrentPatientInfo.PatientCode, FallbackValue='--'}"
                                           Foreground="#FFFFFF" FontWeight="Bold" FontSize="13"
                                           Cursor="Hand" MouseLeftButtonDown="CopyCode_Click"
                                           TextDecorations="Underline"/>
                            </StackPanel>

                            <!-- العمر -->
                            <StackPanel Grid.Column="2" Margin="8,0">
                                <TextBlock Text="العمر:" Foreground="#88AAAAAA" FontSize="11"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding CurrentPatientInfo.ApproxAge, FallbackValue='--'}"
                                               Foreground="#FFFFFF" FontWeight="Bold" FontSize="13"/>
                                    <TextBlock Text="{Binding CurrentPatientInfo.ApproxAgeUnit, FallbackValue='Years'}"
                                               Foreground="#88AAAAAA" FontSize="11" Margin="4,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- الجهة -->
                            <StackPanel Grid.Column="3" Margin="8,0">
                                <TextBlock Text="الجهة:" Foreground="#88AAAAAA" FontSize="11"/>
                                <TextBlock Text="{Binding CurrentPatientInfo.ReferralName, FallbackValue='--'}"
                                           Foreground="#FFFFFF" FontWeight="Bold" FontSize="13"
                                           MaxWidth="200" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>

                        <!-- Lab ID + عدد الزيارات -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <StackPanel Margin="8,0">
                                <TextBlock Text="Lab ID:" Foreground="#88AAAAAA" FontSize="11"/>
                                <TextBlock Text="{Binding CurrentPatientInfo.VisitCode, FallbackValue='--'}"
                                           Foreground="#FFFFFF" FontWeight="Bold" FontSize="13"/>
                            </StackPanel>
                            <Border Background="#2A5A62" CornerRadius="4" Padding="8,4"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="عدد الزيارات: " Foreground="#88AAAAAA"
                                               VerticalAlignment="Center" FontSize="11"/>
                                    <TextBlock Text="{Binding CurrentPatientInfo.SelectedTests.Count, FallbackValue='0'}"
                                               Foreground="#FFFFFF" FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- جدول التحاليل -->
                <DataGrid Grid.Row="1" x:Name="TestsDataGrid"
                          ItemsSource="{Binding PatientTests}"
                          SelectedItem="{Binding SelectedTest}"
                          AutoGenerateColumns="False" IsReadOnly="False"
                          CanUserAddRows="False"
                          RowDetailsVisibilityMode="VisibleWhenSelected"
                          Background="#1A3A44" Foreground="#FFFFFF"
                          RowBackground="#1A3A44" AlternatingRowBackground="#152E36"
                          BorderBrush="#3A5068" BorderThickness="1"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#2A4A54"
                          Margin="4">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick"
                                      Command="{Binding HandleRowActivateCommand}"/>
                        <KeyBinding Key="Enter"
                                    Command="{Binding HandleRowActivateCommand}"/>
                    </DataGrid.InputBindings>
                    <DataGrid.Resources>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="4,2"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1A6EA8"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1A6EA8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <!-- 1. التحليل + أزرار P/T في الرأس -->
                        <DataGridTemplateColumn Header="التحليل" Width="*">
                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                    Margin="4,0,0,0">
                                            <Button Content="P"
                                                    Command="{Binding DataContext.ShowAuditPCommand,
                                                        RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    Width="22" Height="18" Margin="2,0,0,0"
                                                    Background="#8B0000" Foreground="White"
                                                    FontSize="9" FontWeight="Bold" BorderThickness="0"
                                                    ToolTip="سجل تدقيق الزيارة"
                                                    Cursor="Hand"/>
                                            <Button Content="T"
                                                    Command="{Binding DataContext.ShowAuditTCommand,
                                                        RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    Width="22" Height="18" Margin="2,0,0,0"
                                                    Background="#8B0000" Foreground="White"
                                                    FontSize="9" FontWeight="Bold" BorderThickness="0"
                                                    ToolTip="سجل تدقيق التحليل"
                                                    Cursor="Hand"/>
                                        </StackPanel>
                                        <TextBlock Text="التحليل" VerticalAlignment="Center"
                                                   FontWeight="SemiBold"/>
                                    </DockPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TestTypeName}" Foreground="#FFFFFF"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding TestTypeName}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- 2. الكود -->
                        <DataGridTextColumn Header="الكود" Binding="{Binding TestTypeCode}"
                                            IsReadOnly="True" Width="70"/>

                        <!-- 3. النتيجة (قابل للتعديل لأحادي المكوّن فقط) -->
                        <DataGridTemplateColumn Header="النتيجة" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <!-- عرض النص (الحالة الافتراضية) -->
                                        <TextBlock x:Name="ResultDisplay"
                                                   Text="{Binding SingleComponentResultValue}"
                                                   Foreground="#4FC3F7" FontWeight="Bold"
                                                   VerticalAlignment="Center" Padding="4,2"
                                                   ToolTip="{Binding SingleComponentResultValue}"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox x:Name="ResultEditTextBox"
                                             Text="{Binding DataContext.InlineResultValue,
                                                 RelativeSource={RelativeSource AncestorType=Window},
                                                 Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Width="100" Padding="4,2"
                                             Background="#1A4A52" Foreground="#4FC3F7"
                                             BorderBrush="#4CAF50" BorderThickness="1"
                                             FontWeight="Bold"
                                             VerticalContentAlignment="Center"
                                             Loaded="ResultEditTextBox_Loaded"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <!-- 4. الحالة -->
                        <DataGridTemplateColumn Header="الحالة" Width="80" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SingleComponentStatus}"
                                               Style="{StaticResource StatusTextStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- 5. مكتمل (Finish) -->
                        <DataGridTemplateColumn Header="مكتمل" Width="55" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsManuallyOverridden}"
                                              Style="{StaticResource DataGridCheckBox}"
                                              IsEnabled="False"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- 6. مُراجَع (Verify) -->
                        <DataGridTemplateColumn Header="مُراجَع" Width="55" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsAllReviewed, Mode=OneWay}"
                                              Style="{StaticResource DataGridCheckBox}"
                                              IsEnabled="False"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- 7. مطبوع (Print) -->
                        <DataGridTemplateColumn Header="مطبوع" Width="55" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsPrinted}"
                                              Style="{StaticResource DataGridCheckBox}"
                                              IsEnabled="False"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- 8. مُصدَّر (Export) -->
                        <DataGridTemplateColumn Header="مُصدَّر" Width="55" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsExported}"
                                              Style="{StaticResource DataGridCheckBox}"
                                              IsEnabled="False"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>

                    <!-- RowDetailsTemplate: المكوّنات (للتحاليل متعددة المكوّنات فقط) -->
                    <DataGrid.RowDetailsTemplate>
                        <DataTemplate>
                            <Border Background="#152E36" Padding="8" Margin="4,4,4,8"
                                    BorderBrush="#3A5068" BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TotalComponents}" Value="1">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="المكوّنات:"
                                               Foreground="#88AAAAAA" FontWeight="SemiBold"
                                               Margin="0,0,0,4"/>
                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding ComponentResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#1A3A44" CornerRadius="4"
                                                        Padding="8,6" Margin="2">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="150"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="120"/>
                                                            <ColumnDefinition Width="60"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding ComponentName}"
                                                                   FontWeight="SemiBold" Foreground="#FFFFFF"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding ResultValue}"
                                                                   FontWeight="Bold" Foreground="#4FC3F7"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ResultStatus}"
                                                                   FontWeight="Bold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ResultStatus}" Value="HIGH">
                                                                            <Setter Property="Foreground" Value="#F44336"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding ResultStatus}" Value="LOW">
                                                                            <Setter Property="Foreground" Value="#2196F3"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding ResultStatus}" Value="HIGH_CRITICAL">
                                                                            <Setter Property="Foreground" Value="#FF0000"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding ResultStatus}" Value="LOW_CRITICAL">
                                                                            <Setter Property="Foreground" Value="#0000FF"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding ResultStatus}" Value="NORMAL">
                                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Grid.Column="3" Text="{Binding SnapNormalText}"
                                                                   Foreground="#88AAAAAA"/>
                                                        <TextBlock Grid.Column="4" Text="{Binding SnapUnit}"
                                                                   Foreground="#88AAAAAA"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </DataGrid.RowDetailsTemplate>
                </DataGrid>

                <!-- أزرار الإجراءات أسفل الجدول -->
                <Border Grid.Row="2" Background="#0A252C" Padding="6,4" Margin="4,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- طبعت -->
                        <Button Grid.Column="0" Content="طبعت"
                                Command="{Binding TogglePrintCommand}"
                                Style="{StaticResource RowActionButton}"
                                Background="#2A5A62"/>

                        <!-- مراجعة -->
                        <Button Grid.Column="1" Content="مراجعة"
                                Command="{Binding MarkReviewedCommand}"
                                Style="{StaticResource RowActionButton}"
                                Background="#2A5A62"/>

                        <!-- تمت -->
                        <Button Grid.Column="2" Content="تمت"
                                Command="{Binding ManualOverrideCommand}"
                                Style="{StaticResource RowActionButton}"
                                Background="#FF9800"/>

                        <!-- تراجع -->
                        <Button Grid.Column="3" Content="تراجع"
                                Command="{Binding UndoManualOverrideCommand}"
                                Style="{StaticResource RowActionButton}"
                                Background="#607D8B"/>

                        <!-- مربع نص الملاحظات السريعة -->
                        <TextBox Grid.Column="4"
                                 Text="{Binding QuickNoteText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#1A4A52" Foreground="#FFFFFF"
                                 BorderBrush="#3A5068" BorderThickness="1"
                                 Margin="6,0" VerticalContentAlignment="Center"
                                 Padding="4,2" FontSize="11"/>

                        <!-- زر ملاحظات -->
                        <Button Grid.Column="5" Content="ملاحظات"
                                Command="{Binding AddEditNotesCommand}"
                                Style="{StaticResource RowActionButton}"
                                Background="#5C6BC0"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Busy overlay -->
        <Border Grid.Row="0" Grid.ColumnSpan="3"
                Background="#80000000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisConverter}}"
                IsHitTestVisible="True">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="جاري التحميل..." FontSize="18" Foreground="#FFFFFF"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </DockPanel>
</Window>
