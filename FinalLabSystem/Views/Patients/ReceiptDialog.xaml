<Window x:Class="FinalLabSystem.Views.Patients.ReceiptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="طباعة الإيصال" Height="620" Width="560"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        Background="#F5F5F5">
    <Window.Resources>
        <Style x:Key="ReceiptActionButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Background" Value="#A8E000"/>
            <Setter Property="Foreground" Value="#001A20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,6"/>
        </Style>
    </Window.Resources>
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <Button Content="طباعة"
                    Command="{Binding PrintCommand}"
                    Style="{StaticResource ReceiptActionButton}"
                    HorizontalAlignment="Center"
                    Width="200"/>
        </StackPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8">
                <TextBlock Text="نوع القالب" FontWeight="Bold" Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding Formats}"
                          SelectedItem="{Binding SelectedFormat}"
                          Height="32" Width="160"
                          HorizontalAlignment="Right"
                          Margin="0,0,0,12"/>

                <CheckBox Content="إظهار تفاصيل التحاليل"
                          IsChecked="{Binding ShowBreakdown}"
                          Margin="0,0,0,12"/>

                <Border BorderBrush="#CFD8DC" BorderThickness="1"
                        Padding="12" Margin="0,0,0,12"
                        Background="White" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="بيانات المريض"
                                   FontWeight="Bold" FontSize="14"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding VisitData.FullNameAr, TargetNullValue='—'}"
                                   FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding VisitData.PatientCode, StringFormat='الكود: {0}'}"
                                   Margin="0,4,0,0" Foreground="#555"/>
                        <TextBlock Text="{Binding VisitData.EntryDate, StringFormat='التاريخ: {0:yyyy-MM-dd HH:mm}'}"
                                   Margin="0,4,0,0" Foreground="#555"/>
                        <TextBlock Margin="0,4,0,0" Foreground="#555">
                            <Run Text="الاجمالي:"/>
                            <Run Text="{Binding VisitData.Subtotal, StringFormat=N2, Mode=OneWay}"/>
                            <Run Text="  |  الخصم:"/>
                            <Run Text="{Binding VisitData.DiscountAmount, StringFormat=N2, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Margin="0,4,0,0" Foreground="#555">
                            <Run Text="المدفوع:"/>
                            <Run Text="{Binding VisitData.TotalPaid, StringFormat=N2, Mode=OneWay}"/>
                            <Run Text="  |  المتبقي:" FontWeight="Bold"/>
                            <Run Text="{Binding VisitData.BalanceDue, StringFormat=N2, Mode=OneWay}" FontWeight="Bold"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#CFD8DC" BorderThickness="1"
                        Padding="12" Margin="0,0,0,12"
                        Background="White" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="تفاصيل التحاليل"
                                   FontWeight="Bold" FontSize="14"
                                   Margin="0,0,0,6"/>
                        <ItemsControl ItemsSource="{Binding GroupedTests}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="6" Margin="0,0,0,2"
                                            Background="#FAFAFA" CornerRadius="2">
                                        <DockPanel>
                                            <TextBlock Text="{Binding TotalPrice, StringFormat=N2}"
                                                       DockPanel.Dock="Left"
                                                       FontWeight="Bold"
                                                       MinWidth="60"
                                                       TextAlignment="Left"/>
                                            <TextBlock Text="{Binding TestCount}"
                                                       DockPanel.Dock="Right"
                                                       Foreground="#888" FontSize="11"
                                                       MinWidth="30"
                                                       TextAlignment="Center"/>
                                            <StackPanel>
                                                <TextBlock Text="{Binding GroupName}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding DetailLine}"
                                                           FontSize="11" Foreground="#888"
                                                           TextWrapping="Wrap"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
