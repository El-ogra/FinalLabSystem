<Window x:Class="FinalLabSystem.Views.Patients.ReceiptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="الإيصال" Height="360" Width="520"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft">
    <StackPanel Margin="18">
        <TextBlock Text="نوع القالب" FontWeight="Bold" Margin="0,0,0,8"/>
        <ComboBox ItemsSource="{Binding Templates}"
                  SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                  Height="32"
                  Width="160"
                  HorizontalAlignment="Right"/>
        <Border BorderBrush="#CFD8DC" BorderThickness="1" Padding="12" Margin="0,16,0,16">
            <StackPanel>
                <TextBlock Text="{Binding VisitData.FullNameAr, TargetNullValue=لا توجد زيارة محملة}" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding VisitData.PatientCode}" Margin="0,6,0,0"/>
                <TextBlock Text="{Binding VisitData.Subtotal, StringFormat=الإجمالي: {0:N2}}" Margin="0,6,0,0"/>
                <TextBlock Text="{Binding VisitData.DiscountAmount, StringFormat=الخصم: {0:N2}}" Margin="0,6,0,0"/>
                <TextBlock Text="{Binding VisitData.TotalPaid, StringFormat=المدفوع: {0:N2}}" Margin="0,6,0,0"/>
                <TextBlock Text="{Binding VisitData.BalanceDue, StringFormat=المتبقي: {0:N2}}" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>
        <Button Content="معاينة وطباعة" Command="{Binding PreviewAndPrintCommand}" Height="38" Width="150" HorizontalAlignment="Left"/>
    </StackPanel>
</Window>
