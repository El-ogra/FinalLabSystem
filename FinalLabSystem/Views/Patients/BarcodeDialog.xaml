<Window x:Class="FinalLabSystem.Views.Patients.BarcodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:barcoding="clr-namespace:FinalLabSystem.Infrastructure.Barcoding"
        Title="طباعة الباركود" Height="560" Width="720"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft">
    <Window.Resources>
        <barcoding:BarcodeImageConverter x:Key="BarcodeImageConverter"/>
    </Window.Resources>
    <DockPanel Margin="12">
        <Button DockPanel.Dock="Bottom" Content="طباعة الكل"
                Command="{Binding PrintAllCommand}"
                Height="36" Margin="0,10,0,0"/>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Labels}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#333" BorderThickness="1" Margin="6"
                                Width="300" Padding="8">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftDoubleClick"
                                              Command="{Binding DataContext.PrintBarcodeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                              CommandParameter="{Binding}"/>
                            </Border.InputBindings>
                            <StackPanel>
                                <TextBlock Text="{Binding PatientNameAr}"
                                           FontSize="14" FontWeight="Bold"
                                           HorizontalAlignment="Right"
                                           TextWrapping="NoWrap"/>
                                <TextBlock Text="{Binding SexAgeLine}"
                                           FontSize="11" Margin="0,2,0,0"/>
                                <TextBlock Text="{Binding TestCodesLine}"
                                           FontSize="11" Margin="0,2,0,0"/>
                                <Image Source="{Binding BarcodePayload, Converter={StaticResource BarcodeImageConverter}}"
                                       Margin="0,4" HorizontalAlignment="Center"
                                       Stretch="None"/>
                                <TextBlock FontSize="10" Margin="0,2,0,0">
                                    <Run Text="{Binding PatientIdentifierLine}"/>
                                    <Run Text="   "/>
                                    <Run Text="{Binding TubeName}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
