<Window x:Class="FinalLabSystem.Views.Patients.AuditTrailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" Height="500" Width="750"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        Background="#1E2A3A">
    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="{Binding Title}"
                   FontWeight="Bold" FontSize="16" Foreground="#FFFFFF"
                   Margin="0,0,0,8"/>

        <!-- AuditLog data -->
        <DataGrid ItemsSource="{Binding EntriesView}" AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserAddRows="False"
                  Background="#2A3F54" Foreground="#FFFFFF"
                  RowBackground="#2A3F54" AlternatingRowBackground="#1E2A3A"
                  BorderBrush="#3A5068" BorderThickness="1"
                  Visibility="{Binding Entries, Converter={StaticResource NullToVisConverter}}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="التاريخ" Binding="{Binding ChangedAt, StringFormat=g}"
                                    Width="140"/>
                <DataGridTextColumn Header="المستخدم" Binding="{Binding ChangedByNavigation.DisplayName}"
                                    Width="120"/>
                <DataGridTextColumn Header="الإجراء" Binding="{Binding Action}" Width="120"/>
                <DataGridTextColumn Header="الحقل" Binding="{Binding FieldName}" Width="100"/>
                <DataGridTextColumn Header="القيمة القديمة" Binding="{Binding OldValue}" Width="*"/>
                <DataGridTextColumn Header="القيمة الجديدة" Binding="{Binding NewValue}" Width="*"/>
                <DataGridTextColumn Header="ملاحظات" Binding="{Binding Notes}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- VResultAuditTrail data -->
        <DataGrid ItemsSource="{Binding ResultEntriesView}" AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserAddRows="False"
                  Background="#2A3F54" Foreground="#FFFFFF"
                  RowBackground="#2A3F54" AlternatingRowBackground="#1E2A3A"
                  BorderBrush="#3A5068" BorderThickness="1"
                  Visibility="{Binding ResultEntries, Converter={StaticResource NullToVisConverter}}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="التاريخ" Binding="{Binding ChangedAt, StringFormat=g}"
                                    Width="140"/>
                <DataGridTextColumn Header="المستخدم" Binding="{Binding ChangedByName}"
                                    Width="120"/>
                <DataGridTextColumn Header="الإجراء" Binding="{Binding Action}" Width="120"/>
                <DataGridTextColumn Header="الحقل" Binding="{Binding FieldName}" Width="100"/>
                <DataGridTextColumn Header="القديم" Binding="{Binding OldValue}" Width="*"/>
                <DataGridTextColumn Header="الجديد" Binding="{Binding NewValue}" Width="*"/>
                <DataGridTextColumn Header="المريض" Binding="{Binding PatientName}" Width="120"/>
                <DataGridTextColumn Header="التحليل" Binding="{Binding TestType}" Width="120"/>
                <DataGridTextColumn Header="المكوّن" Binding="{Binding ComponentName}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
