<UserControl x:Class="FinalLabSystem.Views.Patients.ReferralSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border IsEnabled="{Binding DataContext.IsFormUnlocked, RelativeSource={RelativeSource AncestorType=Window}}" Background="#123A42"
            BorderBrush="#0A252C"
            BorderThickness="3"
            Padding="4"
            Margin="4"
            FlowDirection="LeftToRight">
        <Border Background="#0B4F78"
                BorderBrush="#0A252C"
                BorderThickness="1"
                Padding="6">
            <Grid>
                <Grid.Resources>
                    <Style x:Key="ReferralInputStyle" TargetType="TextBox">
                        <Setter Property="Height" Value="24"/>
                        <Setter Property="Margin" Value="3"/>
                        <Setter Property="Background" Value="#FFF8DC"/>
                        <Setter Property="BorderBrush" Value="#0A252C"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                    <Style x:Key="ReferralComboStyle" TargetType="ComboBox">
                        <Setter Property="Height" Value="24"/>
                        <Setter Property="Margin" Value="3"/>
                        <Setter Property="Background" Value="#FFF8DC"/>
                        <Setter Property="BorderBrush" Value="#0A252C"/>
                        <Setter Property="BorderThickness" Value="1"/>
                    </Style>
                    <Style x:Key="ReferralLabelStyle" TargetType="Label">
                        <Setter Property="Height" Value="24"/>
                        <Setter Property="Margin" Value="3"/>
                        <Setter Property="Padding" Value="6,1"/>
                        <Setter Property="Background" Value="#7CCB19"/>
                        <Setter Property="Foreground" Value="#1A2600"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="FlowDirection" Value="RightToLeft"/>
                    </Style>
                    <Style x:Key="ReferralBlueLabelStyle" TargetType="Label" BasedOn="{StaticResource ReferralLabelStyle}">
                        <Setter Property="Background" Value="#1E79B8"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Style>
                </Grid.Resources>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.7*"/>
                    <ColumnDefinition Width="0.92*"/>
                    <ColumnDefinition Width="1.35*"/>
                    <ColumnDefinition Width="0.92*"/>
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" ItemsSource="{Binding ReferralSuggestions}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" SelectedItem="{Binding SelectedReferral}" DisplayMemberPath="SourceName" IsEditable="True" Style="{StaticResource ReferralComboStyle}"/>
                <ComboBox Grid.Row="0" Grid.Column="2" ItemsSource="{Binding ReferralTitles}" Text="{Binding ReferralTitle, UpdateSourceTrigger=PropertyChanged}" IsEditable="True" Style="{StaticResource ReferralComboStyle}"/>
                <Label Grid.Row="0" Grid.Column="3" Content="الطبيب المعالج" Style="{StaticResource ReferralLabelStyle}"/>

                <ComboBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" ItemsSource="{Binding ReferralSuggestions}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" SelectedItem="{Binding SelectedReferral}" DisplayMemberPath="SourceName" IsEditable="True" Style="{StaticResource ReferralComboStyle}"/>
                <Label Grid.Row="1" Grid.Column="3" Content="جهة الإحالة" Style="{StaticResource ReferralLabelStyle}"/>

                <TextBox Grid.Row="2" Grid.Column="0" Text="{Binding ReferralAddress}" Style="{StaticResource ReferralInputStyle}"/>
                <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" FlowDirection="RightToLeft" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                    <CheckBox Content="حفظ جهة التحويل" IsChecked="{Binding ShouldSaveReferral}" Foreground="White" Margin="6,0"/>
                    <CheckBox Content="طباعة جهة التحويل" IsChecked="{Binding PrintReferralOnReport}" Foreground="White" Margin="6,0"/>
                </StackPanel>
                <Label Grid.Row="2" Grid.Column="3" Content="العنوان" Style="{StaticResource ReferralBlueLabelStyle}"/>
            </Grid>
        </Border>
    </Border>
</UserControl>
