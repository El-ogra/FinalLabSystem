<Window x:Class="FinalLabSystem.Views.Patients.ProfileSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="اختيار البروفايل"
        Width="450"
        Height="400"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        Background="#1E2A3A"
        ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="اختر البروفايل المطلوب:"
                   Foreground="White"
                   FontWeight="Bold"
                   FontSize="14"
                   Margin="0,0,0,8"/>

        <ListBox Grid.Row="1"
                 x:Name="ProfilesListBox"
                 SelectionMode="Single"
                 Background="#2A3F54"
                 Foreground="White"
                 BorderBrush="#555"
                 BorderThickness="1"
                 MouseDoubleClick="ProfilesListBox_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4">
                        <TextBlock Text="{Binding ProfileNameAr}" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Foreground="#AAA" FontSize="11">
                            <Run Text="{Binding ProfileNameEn, Mode=OneWay}"/>
                            <Run Text=" — "/>
                            <Run Text="{Binding Description, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,12,0,0">
            <Button Content="اختيار"
                    Width="100"
                    Height="32"
                    Background="#4CAF50"
                    Foreground="White"
                    FontWeight="Bold"
                    Margin="0,0,8,0"
                    Click="SelectButton_Click"/>
            <Button Content="إلغاء"
                    Width="100"
                    Height="32"
                    Background="#F44336"
                    Foreground="White"
                    FontWeight="Bold"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
