<UserControl x:Class="FinalLabSystem.Views.Patients.PatientInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Border Background="White"
            BorderBrush="#CCCCCC"
            BorderThickness="1"
            CornerRadius="4"
            Padding="8"
            Margin="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto" MinWidth="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0" Grid.Column="0" Content="كود المريض" VerticalAlignment="Center" Margin="0,3"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding PatientCode, Mode=OneWay}" IsReadOnly="True" Background="#F5F5F5" Margin="0,3" Height="26"/>
            <Label Grid.Row="0" Grid.Column="2" Content="اللقب" VerticalAlignment="Center" Margin="8,3,0,3"/>
            <ComboBox Grid.Row="0" Grid.Column="3" ItemsSource="{Binding TitleSuggestions}" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" IsEditable="True" Margin="0,3" Height="26"/>

            <Label Grid.Row="1" Grid.Column="0" Content="اسم المريض" VerticalAlignment="Center" Margin="0,3"/>
            <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding FullNameAr, UpdateSourceTrigger=PropertyChanged}" Margin="0,3" Height="26"/>

            <Label Grid.Row="2" Grid.Column="0" Content="الجنس" VerticalAlignment="Center" Margin="0,3"/>
            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,3" VerticalAlignment="Center">
                <RadioButton Content="ذكر" GroupName="Sex" IsChecked="{Binding IsMale}" Margin="0,0,12,0"/>
                <RadioButton Content="أنثى" GroupName="Sex" IsChecked="{Binding IsFemale}" Margin="0,0,12,0"/>
                <RadioButton Content="غير محدد" GroupName="Sex" IsChecked="{Binding IsUnknownSex}"/>
            </StackPanel>
            <Label Grid.Row="2" Grid.Column="2" Content="نوع المريض" VerticalAlignment="Center" Margin="8,3,0,3"/>
            <StackPanel Grid.Row="2" Grid.Column="3" Orientation="Horizontal" Margin="0,3" VerticalAlignment="Center">
                <ComboBox ItemsSource="{Binding PatientTypes}" SelectedItem="{Binding PatientType}" Width="120" Height="26"/>
                <CheckBox Content="VIP" IsChecked="{Binding IsVip}" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <Label Grid.Row="3" Grid.Column="0" Content="العمر" VerticalAlignment="Center" Margin="0,3"/>
            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,3" VerticalAlignment="Center">
                <TextBox Text="{Binding ApproxAge, UpdateSourceTrigger=PropertyChanged}" Width="60" Height="26"/>
                <ComboBox SelectedValue="{Binding ApproxAgeUnit}" SelectedValuePath="Content" Width="80" Height="26" Margin="6,0,0,0">
                    <ComboBoxItem Content="سنة"/>
                    <ComboBoxItem Content="شهر"/>
                    <ComboBoxItem Content="يوم"/>
                </ComboBox>
            </StackPanel>

            <Label Grid.Row="4" Grid.Column="0" Content="الهاتف" VerticalAlignment="Center" Margin="0,3"/>
            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Phone}" Margin="0,3" Height="26"/>
            <Label Grid.Row="4" Grid.Column="2" Content="هاتف 2" VerticalAlignment="Center" Margin="8,3,0,3"/>
            <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding Phone2}" Margin="0,3" Height="26"/>

            <Label Grid.Row="5" Grid.Column="0" Content="العنوان" VerticalAlignment="Center" Margin="0,3"/>
            <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Address}" Margin="0,3" Height="26"/>

            <Label Grid.Row="6" Grid.Column="0" Content="البريد" VerticalAlignment="Center" Margin="0,3"/>
            <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Email}" Margin="0,3" Height="26"/>
            <Label Grid.Row="6" Grid.Column="2" Content="الرقم القومي" VerticalAlignment="Center" Margin="8,3,0,3"/>
            <TextBox Grid.Row="6" Grid.Column="3" Text="{Binding NationalId}" Margin="0,3" Height="26"/>

            <Label Grid.Row="7" Grid.Column="0" Content="ملاحظات" VerticalAlignment="Top" Margin="0,3"/>
            <TextBox Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Notes}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="50" Margin="0,3"/>
        </Grid>
    </Border>
</UserControl>
