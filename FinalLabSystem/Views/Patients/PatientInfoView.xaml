<UserControl x:Class="FinalLabSystem.Views.Patients.PatientInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#123A42"
            BorderBrush="#0A252C"
            BorderThickness="3"
            Padding="4"
            Margin="4"
            FlowDirection="LeftToRight">
        <Border Background="#0B4F78"
                BorderBrush="#0A252C"
                BorderThickness="1"
                Padding="6">
            <Grid>
                <Grid.Resources>
                    <Style x:Key="InfoInputStyle" TargetType="TextBox">
                        <Setter Property="Height" Value="24"/>
                        <Setter Property="Margin" Value="3"/>
                        <Setter Property="Background" Value="#FFF8DC"/>
                        <Setter Property="BorderBrush" Value="#0A252C"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                    <Style x:Key="InfoComboStyle" TargetType="ComboBox">
                        <Setter Property="Height" Value="24"/>
                        <Setter Property="Margin" Value="3"/>
                        <Setter Property="Background" Value="#FFF8DC"/>
                        <Setter Property="BorderBrush" Value="#0A252C"/>
                        <Setter Property="BorderThickness" Value="1"/>
                    </Style>
                    <Style x:Key="RedLabelStyle" TargetType="Label">
                        <Setter Property="Height" Value="24"/>
                        <Setter Property="Margin" Value="3"/>
                        <Setter Property="Padding" Value="6,1"/>
                        <Setter Property="Background" Value="#C71919"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="FlowDirection" Value="RightToLeft"/>
                    </Style>
                    <Style x:Key="BlueLabelStyle" TargetType="Label" BasedOn="{StaticResource RedLabelStyle}">
                        <Setter Property="Background" Value="#1E79B8"/>
                    </Style>
                    <Style x:Key="SmallBlueLabelStyle" TargetType="Label" BasedOn="{StaticResource BlueLabelStyle}">
                        <Setter Property="FontSize" Value="11"/>
                    </Style>
                </Grid.Resources>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.45*"/>
                    <ColumnDefinition Width="0.82*"/>
                    <ColumnDefinition Width="0.88*"/>
                    <ColumnDefinition Width="1.45*"/>
                    <ColumnDefinition Width="0.82*"/>
                    <ColumnDefinition Width="0.92*"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Row="0" Grid.Column="0" Text="{Binding PatientCode, Mode=OneWay}" IsReadOnly="True" Style="{StaticResource InfoInputStyle}"/>
                <Label Grid.Row="0" Grid.Column="1" Content="كود المريض" Style="{StaticResource RedLabelStyle}"/>
                <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding DataContext.CurrentVisitId, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}" IsReadOnly="True" Style="{StaticResource InfoInputStyle}"/>
                <Label Grid.Row="0" Grid.Column="3" Content="Lab. ID" Style="{StaticResource BlueLabelStyle}"/>
                <CheckBox Grid.Row="0" Grid.Column="4" IsChecked="{Binding IsVip}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="3"/>
                <Label Grid.Row="0" Grid.Column="5" Content="VIP" Style="{StaticResource BlueLabelStyle}"/>

                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" FlowDirection="LeftToRight" VerticalAlignment="Center" Margin="3">
                    <RadioButton Content="Male" GroupName="Sex" IsChecked="{Binding IsMale}" Foreground="White" Margin="0,0,8,0"/>
                    <RadioButton Content="Female" GroupName="Sex" IsChecked="{Binding IsFemale}" Foreground="White"/>
                </StackPanel>
                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding FullNameAr, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InfoInputStyle}"/>
                <ComboBox Grid.Row="1" Grid.Column="4" ItemsSource="{Binding TitleSuggestions}" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" IsEditable="True" Style="{StaticResource InfoComboStyle}"/>
                <Label Grid.Row="1" Grid.Column="5" Content="اسم المريض" Style="{StaticResource RedLabelStyle}"/>

                <TextBox Grid.Row="2" Grid.Column="0" Text="{Binding ApproxAge, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InfoInputStyle}"/>
                <ComboBox Grid.Row="2" Grid.Column="1" SelectedValue="{Binding ApproxAgeUnit}" SelectedValuePath="Content" Style="{StaticResource InfoComboStyle}">
                    <ComboBoxItem Content="سنة"/>
                    <ComboBoxItem Content="شهر"/>
                    <ComboBoxItem Content="يوم"/>
                </ComboBox>
                <Label Grid.Row="2" Grid.Column="2" Content="سن المريض" Style="{StaticResource BlueLabelStyle}"/>
                <ComboBox Grid.Row="2" Grid.Column="3" Grid.ColumnSpan="2" ItemsSource="{Binding PatientTypes}" SelectedItem="{Binding PatientType}" Style="{StaticResource InfoComboStyle}"/>
                <Label Grid.Row="2" Grid.Column="5" Content="نوع الحساب" Style="{StaticResource BlueLabelStyle}"/>

                <TextBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Phone2}" Style="{StaticResource InfoInputStyle}"/>
                <Label Grid.Row="3" Grid.Column="2" Content="موبايل / تليفون" Style="{StaticResource SmallBlueLabelStyle}"/>
                <TextBox Grid.Row="3" Grid.Column="3" Grid.ColumnSpan="2" Text="{Binding Phone}" Style="{StaticResource InfoInputStyle}"/>
                <Label Grid.Row="3" Grid.Column="5" Content="رقم البطاقة" Style="{StaticResource BlueLabelStyle}"/>

                <TextBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="5" Text="{Binding Address}" Style="{StaticResource InfoInputStyle}"/>
                <Label Grid.Row="4" Grid.Column="5" Content="عنوان المريض" Style="{StaticResource BlueLabelStyle}"/>

                <TextBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding NationalId}" Style="{StaticResource InfoInputStyle}"/>
                <Label Grid.Row="5" Grid.Column="2" Content="الرقم القومي" Style="{StaticResource BlueLabelStyle}"/>
                <TextBox Grid.Row="5" Grid.Column="3" Grid.ColumnSpan="2" Text="{Binding Email}" Style="{StaticResource InfoInputStyle}"/>
                <Label Grid.Row="5" Grid.Column="5" Content="البريد الإلكتروني" Style="{StaticResource SmallBlueLabelStyle}"/>

                <TextBox Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="5" Text="{Binding Notes}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="34" Style="{StaticResource InfoInputStyle}"/>
                <Label Grid.Row="6" Grid.Column="5" Content="ملاحظات" Style="{StaticResource BlueLabelStyle}"/>
            </Grid>
        </Border>
    </Border>
</UserControl>
