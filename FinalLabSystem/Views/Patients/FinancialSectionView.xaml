<UserControl x:Class="FinalLabSystem.Views.Patients.FinancialSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#123A42"
            BorderBrush="#0A252C"
            BorderThickness="3"
            Padding="4"
            FlowDirection="LeftToRight">
        <Border Background="#FFD91A"
                BorderBrush="#F4A300"
                BorderThickness="2"
                Padding="6">
            <Grid HorizontalAlignment="Stretch"
                  VerticalAlignment="Bottom">
                <Grid.Resources>
                    <Style x:Key="FinanceTextBoxStyle" TargetType="TextBox">
                        <Setter Property="Height" Value="24"/>
                        <Setter Property="Margin" Value="3"/>
                        <Setter Property="Padding" Value="4,1"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="BorderBrush" Value="#7A8A8A"/>
                        <Setter Property="BorderThickness" Value="1"/>
                    </Style>
                    <Style x:Key="FinanceLabelStyle" TargetType="Label">
                        <Setter Property="Height" Value="24"/>
                        <Setter Property="Margin" Value="3"/>
                        <Setter Property="Padding" Value="4,1"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="FlowDirection" Value="RightToLeft"/>
                    </Style>
                    <Style x:Key="FinanceButtonStyle" TargetType="Button">
                        <Setter Property="Height" Value="28"/>
                        <Setter Property="Margin" Value="3"/>
                        <Setter Property="Padding" Value="8,2"/>
                        <Setter Property="MinWidth" Value="58"/>
                        <Setter Property="Background" Value="#9CCC22"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                    </Style>
                </Grid.Resources>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*"/>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="0.72*"/>
                    <ColumnDefinition Width="0.72*"/>
                    <ColumnDefinition Width="1.1*"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Row="0"
                         Grid.Column="0"
                         Text="{Binding BalanceDue, Mode=OneWay}"
                         IsReadOnly="True"
                         Background="#75C83A"
                         Foreground="White"
                         Style="{StaticResource FinanceTextBoxStyle}"/>
                <Label Grid.Row="0"
                       Grid.Column="1"
                       Content="الباقي للمعمل"
                       Background="#F58220"
                       Style="{StaticResource FinanceLabelStyle}"/>
                <TextBox Grid.Row="0"
                         Grid.Column="2"
                         Text="{Binding Subtotal, Mode=OneWay}"
                         IsReadOnly="True"
                         Background="#4C90CD"
                         Foreground="White"
                         Style="{StaticResource FinanceTextBoxStyle}"/>
                <Label Grid.Row="0"
                       Grid.Column="4"
                       Content="اجمالي التحاليل"
                       Background="#C71919"
                       Style="{StaticResource FinanceLabelStyle}"/>

                <TextBox Grid.Row="1"
                         Grid.Column="0"
                         Text="{Binding BalanceDue, Mode=OneWay}"
                         IsReadOnly="True"
                         Background="#75C83A"
                         Foreground="White"
                         Style="{StaticResource FinanceTextBoxStyle}"/>
                <Label Grid.Row="1"
                       Grid.Column="1"
                       Content="الباقي للمريض"
                       Background="#F58220"
                       Style="{StaticResource FinanceLabelStyle}"/>
                <TextBox Grid.Row="1"
                         Grid.Column="2"
                         Text="{Binding DiscountPercent, UpdateSourceTrigger=PropertyChanged}"
                         Background="#F6FDE5"
                         Style="{StaticResource FinanceTextBoxStyle}"/>
                <TextBox Grid.Row="1"
                         Grid.Column="3"
                         Text="{Binding DiscountAmount, UpdateSourceTrigger=PropertyChanged}"
                         Background="#F6FDE5"
                         Style="{StaticResource FinanceTextBoxStyle}"/>
                <Label Grid.Row="1"
                       Grid.Column="4"
                       Content="الخصم"
                       Background="#376FA8"
                       Style="{StaticResource FinanceLabelStyle}"/>

                <TextBox Grid.Row="2"
                         Grid.Column="0"
                         Text="{Binding AmountPaid, UpdateSourceTrigger=PropertyChanged}"
                         Background="#FFFDE7"
                         Style="{StaticResource FinanceTextBoxStyle}"/>
                <Label Grid.Row="2"
                       Grid.Column="1"
                       Content="المدفوع"
                       Background="#D70000"
                       Style="{StaticResource FinanceLabelStyle}"/>
                <TextBox Grid.Row="2"
                         Grid.Column="2"
                         Text="{Binding DiscountAmount, UpdateSourceTrigger=PropertyChanged}"
                         Background="#4C90CD"
                         Foreground="White"
                         Style="{StaticResource FinanceTextBoxStyle}"/>
                <Label Grid.Row="2"
                       Grid.Column="4"
                       Content="قيمة الخصم"
                       Background="#376FA8"
                       Style="{StaticResource FinanceLabelStyle}"/>

                <Button Grid.Row="3"
                        Grid.Column="0"
                        Content="تم الدفع"
                        Command="{Binding ConfirmPaymentCommand}"
                        Style="{StaticResource FinanceButtonStyle}"/>
                <Button Grid.Row="3"
                        Grid.Column="1"
                        Content="تراجع"
                        Command="{Binding RevertCommand}"
                        Style="{StaticResource FinanceButtonStyle}"/>
                <Button Grid.Row="3"
                        Grid.Column="2"
                        Content="خالص"
                        Command="{Binding ClearanceCommand}"
                        Style="{StaticResource FinanceButtonStyle}"/>
                <TextBox Grid.Row="3"
                         Grid.Column="3"
                         Text="{Binding TotalAfterDiscount, Mode=OneWay}"
                         IsReadOnly="True"
                         Background="#4C90CD"
                         Foreground="White"
                         Style="{StaticResource FinanceTextBoxStyle}"/>
                <Label Grid.Row="3"
                       Grid.Column="4"
                       Content="التكلفة بعد الخصم"
                       Background="#376FA8"
                       Style="{StaticResource FinanceLabelStyle}"/>

                <TextBox Grid.Row="4"
                         Grid.Column="3"
                         Text="{Binding PreviouslyPaid, Mode=OneWay}"
                         IsReadOnly="True"
                         Background="#4C90CD"
                         Foreground="White"
                         Style="{StaticResource FinanceTextBoxStyle}"/>
                <Label Grid.Row="4"
                       Grid.Column="4"
                       Content="المدفوع سابقا"
                       Background="#376FA8"
                       Style="{StaticResource FinanceLabelStyle}"/>
            </Grid>
        </Border>
    </Border>
</UserControl>
