<Window x:Class="FinalLabSystem.Views.Patients.ResultEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إدخال نتيجة التحليل" Height="450" Width="650"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        Background="#1E2A3A">
    <DockPanel Margin="8">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="{Binding TestTypeName}" FontWeight="Bold" FontSize="16"
                       Foreground="#FFFFFF" Margin="0,0,0,4"/>
        </StackPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Left" Margin="0,8,0,0">
            <Button Content="حفظ" Command="{Binding SaveCommand}" Width="100" Height="32"
                    Background="#4CAF50" Foreground="White" FontWeight="Bold"
                    Margin="0,0,8,0"/>
            <Button Content="إلغاء" Command="{Binding CancelCommand}" Width="100" Height="32"
                    Background="#F44336" Foreground="White" FontWeight="Bold"
                    IsCancel="True"/>
        </StackPanel>
        <DataGrid ItemsSource="{Binding Components}" AutoGenerateColumns="False"
                  IsReadOnly="False" CanUserAddRows="False"
                  Background="#2A3F54" Foreground="#FFFFFF"
                  RowBackground="#2A3F54" AlternatingRowBackground="#1E2A3A"
                  BorderBrush="#3A5068" BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="الكود" Binding="{Binding ComponentCode}"
                                    IsReadOnly="True" Width="80"/>
                <DataGridTextColumn Header="المكوّن" Binding="{Binding ComponentName}"
                                    IsReadOnly="True" Width="*"/>
                <DataGridTemplateColumn Header="النتيجة" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding ResultValue, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" Foreground="#FFFFFF"
                                     BorderBrush="#555" BorderThickness="1" Padding="4,2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="الوحدة" Binding="{Binding SnapUnit}"
                                    IsReadOnly="True" Width="70"/>
                <DataGridTextColumn Header="المدى" Binding="{Binding SnapNormalText}"
                                    IsReadOnly="True" Width="100"/>
                <DataGridTextColumn Header="الحالة" Binding="{Binding ResultStatus}"
                                    IsReadOnly="True" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
