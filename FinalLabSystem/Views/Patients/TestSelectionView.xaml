<UserControl x:Class="FinalLabSystem.Views.Patients.TestSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="White" Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" FlowDirection="LeftToRight" Margin="4">
            <RadioButton Content="Routine Tests" GroupName="TestFilter" IsChecked="True" Command="{Binding SetFilterCommand}" CommandParameter="RoutineTests" Margin="0,0,10,0"/>
            <RadioButton Content="Profiles" GroupName="TestFilter" Command="{Binding SetFilterCommand}" CommandParameter="Profiles" Margin="0,0,10,0"/>
            <RadioButton Content="By Group" GroupName="TestFilter" Command="{Binding SetFilterCommand}" CommandParameter="ByGroup" Margin="0,0,10,0"/>
            <RadioButton Content="By Category" GroupName="TestFilter" Command="{Binding SetFilterCommand}" CommandParameter="ByCategory"/>
        </WrapPanel>

        <TextBox Grid.Row="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="4" Height="28"/>

        <Grid Grid.Row="2" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Label Grid.Row="0" Content="التحاليل المتاحة" FontWeight="Bold" Margin="4,2"/>
                <ListView Grid.Row="1"
                          ItemsSource="{Binding AvailableTests}"
                          SelectedItem="{Binding SelectedAvailableTest}"
                          VirtualizingPanel.IsVirtualizing="True"
                          MouseDoubleClick="AvailableTests_OnMouseDoubleClick">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="التحليل" DisplayMemberBinding="{Binding Name}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>

            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#CFD8DC"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4,2">
                    <Label Content="التحاليل المختارة" FontWeight="Bold" Padding="0"/>
                    <Label Content="{Binding SelectedTestsCount, Mode=OneWay}" ContentStringFormat="({0})" Padding="6,0,0,0"/>
                </StackPanel>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding SelectedTests}"
                          SelectedItem="{Binding SelectedTest}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="الكود" Binding="{Binding Code}" Width="60"/>
                        <DataGridTextColumn Header="التحليل" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="السعر" Binding="{Binding Price}" Width="70"/>
                        <DataGridTextColumn Header="العينة" Binding="{Binding SampleType}" Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <DockPanel Grid.Row="3" Margin="4">
            <Button Content="Add select test" Command="{Binding AddTestCommand}" DockPanel.Dock="Left" Width="130" Height="32"/>
            <Button Content="All" Command="{Binding RemoveAllCommand}" DockPanel.Dock="Right" Width="90" Height="32"/>
            <Button Content="Delete" Command="{Binding RemoveTestCommand}" DockPanel.Dock="Right" Width="90" Height="32" Margin="4,0"/>
        </DockPanel>
    </Grid>
</UserControl>
