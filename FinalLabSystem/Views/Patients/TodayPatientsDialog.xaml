<Window x:Class="FinalLabSystem.Views.Patients.TodayPatientsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="مرضى اليوم"
        Height="420"
        Width="520"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        ResizeMode="CanResize"
        Loaded="Window_Loaded">
    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top"
                   Text="مرضى اليوم"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <TextBox DockPanel.Dock="Top"
                 Height="32"
                 Margin="0,0,0,10"
                 Padding="6,2"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="0,10,0,0">
            <Button Content="اختيار"
                    Width="100"
                    Height="34"
                    Margin="8,0,0,0"
                    Command="{Binding SelectCommand}"/>
            <Button Content="إلغاء"
                    Width="100"
                    Height="34"
                    Command="{Binding CancelCommand}"/>
        </StackPanel>

        <ListView ItemsSource="{Binding PatientsView}"
                  SelectedItem="{Binding SelectedPatient}"
                  SelectionMode="Single">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="كود المريض"
                                    Width="150"
                                    DisplayMemberBinding="{Binding PatientCode}"/>
                    <GridViewColumn Header="اسم المريض"
                                    Width="300"
                                    DisplayMemberBinding="{Binding FullNameAr}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>
