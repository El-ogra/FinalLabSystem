<Window x:Class="FinalLabSystem.Views.Patients.TodayPatientsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="مرضى اليوم"
        Height="420"
        Width="520"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        ResizeMode="CanResize">
    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top"
                   Text="مرضى اليوم"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <TextBox x:Name="SearchBox"
                 DockPanel.Dock="Top"
                 Height="32"
                 Margin="0,0,0,10"
                 Padding="6,2"
                 TextChanged="SearchBox_OnTextChanged"/>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="0,10,0,0">
            <Button Content="اختيار"
                    Width="100"
                    Height="34"
                    Margin="8,0,0,0"
                    Click="SelectButton_OnClick"/>
            <Button Content="إلغاء"
                    Width="100"
                    Height="34"
                    Click="CancelButton_OnClick"/>
        </StackPanel>

        <ListView x:Name="PatientsList"
                  ItemsSource="{Binding}"
                  SelectionMode="Single"
                  MouseDoubleClick="PatientsList_OnMouseDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="كود المريض"
                                    Width="150"
                                    DisplayMemberBinding="{Binding PatientCode}"/>
                    <GridViewColumn Header="اسم المريض"
                                    Width="300"
                                    DisplayMemberBinding="{Binding FullNameAr}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>
