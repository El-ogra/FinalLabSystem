<UserControl x:Class="FinalLabSystem.Views.Patients.TestSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#123A42"
            BorderBrush="#0A252C"
            BorderThickness="3"
            Padding="4"
            Margin="4"
            FlowDirection="LeftToRight">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="start"
                        Width="46"
                        Height="24"
                        Margin="0,0,4,0"
                        Background="#A8E000"
                        Foreground="#001A20"
                        FontWeight="Bold"
                        Command="{Binding SetFilterCommand}"
                        CommandParameter="RoutineTests"/>
                <TextBox Grid.Column="1"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Height="24"
                         Margin="0,0,8,0"
                         Background="#FFF8DC"/>
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            FlowDirection="LeftToRight">
                    <RadioButton Content="TM" GroupName="TestFilter" IsChecked="True" Command="{Binding SetFilterCommand}" CommandParameter="RoutineTests" Foreground="#FFF8DC" Margin="0,0,6,0"/>
                    <RadioButton Content="TG" GroupName="TestFilter" Command="{Binding SetFilterCommand}" CommandParameter="ByGroup" Foreground="#FFF8DC" Margin="0,0,6,0"/>
                    <RadioButton Content="CG" GroupName="TestFilter" Command="{Binding SetFilterCommand}" CommandParameter="ByCategory" Foreground="#FFF8DC" Margin="0,0,6,0"/>
                    <TextBlock Text="complete test menu" Foreground="#FFEB3B" FontStyle="Italic" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.45*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Label Grid.Row="0"
                           Content="التحاليل المتاحة"
                           Background="#A8E000"
                           Foreground="#001A20"
                           FontWeight="Bold"
                           HorizontalContentAlignment="Right"
                           Padding="6,2"
                           FlowDirection="RightToLeft"/>
                    <ListView Grid.Row="1"
                              ItemsSource="{Binding AvailableTests}"
                              SelectedItem="{Binding SelectedAvailableTest}"
                              VirtualizingPanel.IsVirtualizing="True"
                              MouseDoubleClick="AvailableTests_OnMouseDoubleClick"
                              Background="#EAF4CF"
                              BorderBrush="#0A252C"
                              BorderThickness="1"
                              FlowDirection="LeftToRight">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="التحليل" DisplayMemberBinding="{Binding Name}" Width="240"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>

                <GridSplitter Grid.Column="1"
                              Width="6"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="#0A252C"/>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0"
                               Content="Patient's tests"
                               Background="#6D9130"
                               Foreground="#FFF8DC"
                               FontWeight="Bold"
                               HorizontalContentAlignment="Center"
                               Padding="6,2"/>
                        <Label Grid.Column="1"
                               Content="{Binding SelectedTestsCount, Mode=OneWay}"
                               Background="#C24B0C"
                               Foreground="White"
                               FontWeight="Bold"
                               HorizontalContentAlignment="Center"
                               Padding="6,2"/>
                    </Grid>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding SelectedTests}"
                              SelectedItem="{Binding SelectedTest}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Background="#3B5B55"
                              Foreground="#FFF8DC"
                              BorderBrush="#0A252C"
                              BorderThickness="1"
                              FlowDirection="RightToLeft">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="الكود" Binding="{Binding Code}" Width="60"/>
                            <DataGridTextColumn Header="التحليل" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="السعر" Binding="{Binding Price}" Width="70"/>
                            <DataGridTextColumn Header="العينة" Binding="{Binding SampleType}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>

            <Grid Grid.Row="2" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.45*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Add select test"
                        Command="{Binding AddTestCommand}"
                        Height="30"
                        HorizontalAlignment="Stretch"
                        Background="#A8E000"
                        Foreground="#001A20"
                        FontWeight="Bold"/>

                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="Delete"
                            Command="{Binding RemoveTestCommand}"
                            Height="30"
                            Margin="0,0,2,0"
                            Background="#A8E000"
                            Foreground="#001A20"
                            FontWeight="Bold"/>
                    <Button Grid.Column="1"
                            Content="All"
                            Command="{Binding RemoveAllCommand}"
                            Height="30"
                            Margin="2,0,0,0"
                            Background="#A8E000"
                            Foreground="#001A20"
                            FontWeight="Bold"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
