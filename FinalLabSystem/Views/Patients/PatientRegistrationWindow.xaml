<Window x:Class="FinalLabSystem.Views.Patients.PatientRegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:patients="clr-namespace:FinalLabSystem.Views.Patients"
        Title="إضافة وتعديل بيانات المرضى"
        Height="820"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft">
    <Grid Background="#F5F7FA" Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="55*"/>
            <ColumnDefinition Width="45*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0"
              Margin="4,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2.4*"/>
                <RowDefinition Height="0.95*"/>
                <RowDefinition Height="1.45*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#ECEFF1"
                    BorderBrush="#CFD8DC"
                    BorderThickness="0,0,0,1"
                    Padding="8"
                    Margin="4,0,4,6">
                <StackPanel Orientation="Horizontal"
                            FlowDirection="RightToLeft"
                            HorizontalAlignment="Right">
                    <Label Content="تاريخ الدخول" VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <DatePicker SelectedDate="{Binding EntryDate}" Width="170" Height="28" Margin="0,0,12,0"/>
                    <Label Content="تاريخ الاستلام المتوقع" VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <DatePicker SelectedDate="{Binding ExpectedReady}" Width="170" Height="28" Margin="0,0,12,0"/>
                    <Label Content="كود المريض" VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <TextBox Text="{Binding PatientInfo.PatientCode, Mode=OneWay}"
                             IsReadOnly="True"
                             Width="170"
                             Height="28"
                             Background="#F5F5F5"/>
                </StackPanel>
            </Border>

            <patients:PatientInfoView Grid.Row="1" DataContext="{Binding PatientInfo}"/>
            <patients:ReferralSectionView Grid.Row="2" DataContext="{Binding Referral}"/>
            <patients:MedicalHistorySectionView Grid.Row="3" DataContext="{Binding MedicalHistory}"/>

            <Border Grid.Row="4"
                    Background="#123A42"
                    BorderBrush="#0A252C"
                    BorderThickness="3"
                    Padding="5"
                    Margin="4,4,4,0"
                    FlowDirection="RightToLeft">
                <Grid>
                    <Grid.Resources>
                        <Style x:Key="MainActionButtonStyle" TargetType="Button">
                            <Setter Property="Height" Value="38"/>
                            <Setter Property="Margin" Value="4"/>
                            <Setter Property="MinWidth" Value="112"/>
                            <Setter Property="Background" Value="#A8E000"/>
                            <Setter Property="Foreground" Value="#001A20"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </Grid.Resources>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Row="0" Grid.Column="0" Content="إضافة" Command="{Binding AddNewCommand}" Style="{StaticResource MainActionButtonStyle}"/>
                    <Button Grid.Row="0" Grid.Column="1" Content="تعديل" Command="{Binding EditCommand}" Style="{StaticResource MainActionButtonStyle}"/>
                    <Button Grid.Row="0" Grid.Column="2" Content="حفظ" Command="{Binding SaveCommand}" Style="{StaticResource MainActionButtonStyle}" Background="#8BC34A"/>
                    <Button Grid.Row="0" Grid.Column="3" Content="حذف" Command="{Binding DeleteCommand}" Style="{StaticResource MainActionButtonStyle}"/>

                    <Button Grid.Row="1" Grid.Column="0" Content="الإيصال" Command="{Binding ReceiptCommand}" Style="{StaticResource MainActionButtonStyle}"/>
                    <Button Grid.Row="1" Grid.Column="1" Content="الباركود" Command="{Binding BarcodeCommand}" Style="{StaticResource MainActionButtonStyle}"/>
                    <Button Grid.Row="1" Grid.Column="2" Content="ورقة العمل" Style="{StaticResource MainActionButtonStyle}"/>
                    <Button Grid.Row="1" Grid.Column="3" Content="الكارنيه" Style="{StaticResource MainActionButtonStyle}"/>

                    <Button Grid.Row="2" Grid.Column="0" Content="قائمة المرضى" Command="{Binding LoadTodayPatientsCommand}" Style="{StaticResource MainActionButtonStyle}"/>
                    <Button Grid.Row="2" Grid.Column="1" Content="نتائج التحاليل" Style="{StaticResource MainActionButtonStyle}"/>
                    <Button Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Content="القائمة الرئيسية" Command="{Binding ReturnToMainCommand}" Style="{StaticResource MainActionButtonStyle}"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="1"
              Margin="0,0,4,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <patients:TestSelectionView Grid.Row="0" DataContext="{Binding TestSelection}"/>
            <Border Grid.Row="1"
                    Background="#123A42"
                    BorderBrush="#0A252C"
                    BorderThickness="3"
                    Padding="4"
                    Margin="4,0,4,4"
                    FlowDirection="LeftToRight">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                    <Border Background="#F58220"
                            BorderBrush="#F4A300"
                            BorderThickness="2"
                            Padding="8,2"
                            Margin="0,0,6,0">
                        <TextBlock Text="Taken outside lab"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <CheckBox Margin="0,0,3,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Urine" Background="#FFE47A" Foreground="#3B3200" FontWeight="Bold" Padding="6,2" Margin="0,0,5,0"/>
                    <CheckBox Margin="0,0,3,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Stool" Background="#FFE47A" Foreground="#3B3200" FontWeight="Bold" Padding="6,2" Margin="0,0,5,0"/>
                    <CheckBox Margin="0,0,3,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Blood" Background="#FFE47A" Foreground="#C71919" FontWeight="Bold" Padding="6,2" Margin="0,0,5,0"/>
                    <CheckBox Margin="0,0,3,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Semen" Background="#FFE47A" Foreground="#3B3200" FontWeight="Bold" Padding="6,2" Margin="0,0,5,0"/>
                    <CheckBox Margin="0,0,3,0" VerticalAlignment="Center"/>
                    <TextBlock Text="CSF" Background="#FFE47A" Foreground="#3B3200" FontWeight="Bold" Padding="6,2"/>
                </StackPanel>
            </Border>
            <patients:FinancialSectionView Grid.Row="2" DataContext="{Binding Financial}" Margin="4,0,4,0"/>
        </Grid>
    </Grid>
</Window>
