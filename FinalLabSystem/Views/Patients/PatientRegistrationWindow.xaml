<Window x:Class="FinalLabSystem.Views.Patients.PatientRegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:patients="clr-namespace:FinalLabSystem.Views.Patients"
        Title="إضافة وتعديل بيانات المرضى"
        Height="820"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft">
    <Grid Background="#F5F7FA" Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="55*"/>
            <ColumnDefinition Width="45*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Background="#ECEFF1"
                BorderBrush="#CFD8DC"
                BorderThickness="0,0,0,1"
                Padding="10"
                Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal"
                        FlowDirection="RightToLeft"
                        HorizontalAlignment="Right">
                <Label Content="تاريخ الدخول" VerticalAlignment="Center" Margin="8,0,4,0"/>
                <DatePicker SelectedDate="{Binding EntryDate}" Width="180" Height="30" Margin="0,0,12,0"/>
                <Label Content="تاريخ الاستلام المتوقع" VerticalAlignment="Center" Margin="8,0,4,0"/>
                <DatePicker SelectedDate="{Binding ExpectedReady}" Width="180" Height="30" Margin="0,0,12,0"/>
                <Label Content="كود المريض" VerticalAlignment="Center" Margin="8,0,4,0"/>
                <TextBox Text="{Binding PatientInfo.PatientCode, Mode=OneWay}"
                         IsReadOnly="True"
                         Width="180"
                         Height="30"
                         Background="#F5F5F5"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1"
              Grid.Column="0"
              Margin="4,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="2.5*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1.5*"/>
            </Grid.RowDefinitions>
            <patients:PatientInfoView Grid.Row="0" DataContext="{Binding PatientInfo}"/>
            <patients:ReferralSectionView Grid.Row="1" DataContext="{Binding Referral}"/>
            <patients:MedicalHistorySectionView Grid.Row="2" DataContext="{Binding MedicalHistory}"/>
        </Grid>

        <patients:TestSelectionView Grid.Row="1"
                                    Grid.Column="1"
                                    DataContext="{Binding TestSelection}"
                                    Margin="0,0,4,8"/>

        <patients:FinancialSectionView Grid.Row="2"
                                       Grid.Column="0"
                                       Grid.ColumnSpan="2"
                                       DataContext="{Binding Financial}"
                                       Margin="0,0,0,8"/>

        <Border Grid.Row="3"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Background="#ECEFF1"
                BorderBrush="#CFD8DC"
                BorderThickness="0,1,0,0"
                Padding="10">
            <StackPanel Orientation="Horizontal"
                        FlowDirection="RightToLeft"
                        HorizontalAlignment="Right">
                <Button Content="إضافة مريض" Command="{Binding AddNewCommand}" Height="40" MinWidth="100" Margin="4,0"/>
                <Button Content="تعديل" Command="{Binding EditCommand}" Height="40" MinWidth="100" Margin="4,0"/>
                <Button Content="حذف" Command="{Binding DeleteCommand}" Height="40" MinWidth="100" Margin="4,0"/>
                <Button Content="حفظ" Command="{Binding SaveCommand}" Height="40" MinWidth="100" Margin="4,0" Background="#2196F3" Foreground="White"/>
                <Button Content="الباركود" Command="{Binding BarcodeCommand}" Height="40" MinWidth="100" Margin="4,0"/>
                <Button Content="الإيصال" Command="{Binding ReceiptCommand}" Height="40" MinWidth="100" Margin="4,0"/>
                <Button Content="مرضى اليوم" Command="{Binding LoadTodayPatientsCommand}" Height="40" MinWidth="100" Margin="4,0"/>
                <Button Content="القائمة الرئيسية" Command="{Binding ReturnToMainCommand}" Height="40" MinWidth="100" Margin="4,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
