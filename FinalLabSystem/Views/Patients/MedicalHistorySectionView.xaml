<UserControl x:Class="FinalLabSystem.Views.Patients.MedicalHistorySectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Border Background="White"
            BorderBrush="#CCCCCC"
            BorderThickness="1"
            CornerRadius="4"
            Padding="8"
            Margin="4">
        <StackPanel Orientation="Vertical">
            <WrapPanel Orientation="Horizontal" Margin="0,0,0,6">
                <CheckBox Content="صائم" IsChecked="{Binding IsFasting}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Visibility="{Binding IsFasting, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="8,0,0,0">
                    <Label Content="ساعات الصيام" VerticalAlignment="Center" Padding="0"/>
                    <TextBox Text="{Binding FastingHours}" Width="50" Height="24" Margin="6,0,0,0"/>
                </StackPanel>
                <CheckBox Content="حامل" IsChecked="{Binding IsPregnant}" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </WrapPanel>

            <Label Content="نوع العينة (للعرض فقط)" Padding="0" Margin="0,0,0,3"/>
            <WrapPanel Orientation="Horizontal" Margin="0,0,0,6">
                <ToggleButton Content="Blood" Margin="2" Padding="6,2"/>
                <ToggleButton Content="Urine" Margin="2" Padding="6,2"/>
                <ToggleButton Content="Stool" Margin="2" Padding="6,2"/>
                <ToggleButton Content="Semen" Margin="2" Padding="6,2"/>
                <ToggleButton Content="CSF" Margin="2" Padding="6,2"/>
            </WrapPanel>

            <Label Content="ملاحظات الزيارة" Padding="0" Margin="0,0,0,3"/>
            <TextBox Text="{Binding VisitNotes}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="40" MaxHeight="70"/>
        </StackPanel>
    </Border>
</UserControl>
